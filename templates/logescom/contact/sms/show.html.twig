{% extends 'base_admin.html.twig' %}

{% set queryParams = app.request.query.all %}
{% set queryString = queryParams|filter((v, k) => k != "page" and k != "ajustement" and k != "id_stock") | url_encode %}

{% block title %}SMS - Orange Configuration{% endblock %}


{% block presentation %}
    <div class="container-fluid py-3">
        <div class="row">
            {% include "_common/_nav_direction.html.twig" %}

            <div class="col-md-10 ms-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Détails du Forfait SMS</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless">
                            <tbody>
                                <tr>
                                    <th class="text-muted">ID</th>
                                    <td>{{ achat.id }}</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Forfait</th>
                                    <td>{{ achat.forfait.nom|capitalize ~ ' (' ~ achat.forfait.remarque|capitalize ~ ')' }}</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">SMS</th>
                                    <td>{{ smsEnvoyes|length }} / {{ achat.forfait.sms|number_format(0, ',', ' ') }} SMS</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Prix Achat</th>
                                    <td>{{ achat.prix|number_format(0, ',', ' ') }} GNF</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Date de Souscription</th>
                                    <td>{{ achat.dateSouscription ? achat.dateSouscription|date('d/m/Y H:i:s') : '' }}</td>
                                </tr>
                                {# <tr>
                                    <th class="text-muted">Acheteur</th>
                                    <td>{{ achat.saisiePar.prenom|capitalize ~ ' ' ~ achat.saisiePar.nom|upper }}</td>
                                </tr> #}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card shadow-sm border-0 mt-4">
                    <div class="card-header bg-warning text-white text-center">
                        <h5 class="mb-0">SMS Envoyés</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-light text-center">
                                <tr>
                                    <th scope="col">#</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Destinataire</th>
                                    <th scope="col">Message</th>
                                    <th scope="col">Détails</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for sms in smsEnvoyes %}
                                    <tr>
                                        <td class="text-center">{{ loop.index }}</td>
                                        <td class="text-center">{{ sms.dateEnvoie ? sms.dateEnvoie|date('d/m/Y') : '' }}</td>
                                        <td class="text-center">{{ sms.destinataire }}</td>
                                        <td>{{ sms.message|capitalize }}</td>
                                        <td>{{ sms.commentaire|capitalize }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">Aucun SMS envoyé pour ce forfait.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
