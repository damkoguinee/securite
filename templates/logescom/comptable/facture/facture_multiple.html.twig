{# ===================== HEADER ===================== #}
<table class="header-table" style="width:100%;">
    <thead>
        <tr>
            <td style="width:25%;">
                <img src="data:image/png;base64,{{ logoPath }}" style="width:110px;">
            </td>

            <td style="width:50%; text-align:center;">
                <strong style="font-size:14px;">{{ site.entreprise.nom|upper }}</strong><br>
                {{ site.adresse.nom }}<br>
                {{ site.description }}<br>
                Tél : {{ site.telephone }}<br>
                <span style="font-size:11px;">{{ site.entreprise.numeroAgrement }}</span>
            </td>

            <td style="width:25%; text-align:right; font-size:12px;">
                <strong>Facture :</strong> {{ factures[0].entity.reference }}<br>
                <strong>Émise le :</strong> {{ factures[0].entity.dateEmission|date('d/m/Y') }}<br>
                <strong>Période :</strong><br>
                {{ factures[0].entity.periodeDebut|date('d/m/Y') }} → {{ factures[0].entity.periodeFin|date('d/m/Y') }}
            </td>
        </tr>
    </thead>
</table>

<!-- ===================== TITRE ===================== -->
<h1>
    Facture de Surveillance
    <div style="font-size:12px; font-weight:normal; margin-top:3px;">
        Client : {{ client.nomComplet }} - {{ client.telephone }}
    </div>
</h1>

<!-- ===================== INFORMATIONS ===================== -->
<h2>Informations</h2>

<table class="bordered">
    <tr><th>Facture N°</th><td>{{ factures[0].entity.reference }}</td></tr>
    <tr><th>Date émission</th><td>{{ factures[0].entity.dateEmission|date('d/m/Y') }}</td></tr>
    <tr><th>Date d’échéance</th><td style="color:#d00; font-weight:bold;">{{ factures[0].entity.dateEcheance|date('d/m/Y') }}</td></tr>
    <tr>
        <th>Période facturée</th>
        <td>Du {{ factures[0].entity.periodeDebut|date('d/m/Y') }} au {{ factures[0].entity.periodeFin|date('d/m/Y') }}</td>
    </tr>
</table>

{# =================== INIT TOTAUX GLOBAUX =================== #}
{% set total_global_ttc = 0 %}
{% set total_global_paye = 0 %}

{% for f in factures %}

    {% set facture = f.entity %}
    {% set calc = f.pdf.calcul %}
    {% set prorata = f.pdf.prorata %}

    {# cumuls globaux #}
    {% set total_global_ttc = total_global_ttc + facture.montantTotal %}
    {% set total_global_paye = total_global_paye + facture.montantPaye %}

    {% if mode != 'horaire' %}
        <h2>{{ facture.contrat.bien.nom }}</h2>

        {# ===== TON CODE EXISTANT : LIGNES DE FACTURATION (INCHANGÉ) ===== #}

        {% set hasRemise = facture.remisePourcentage and facture.remisePourcentage > 0 %}
        {% set hasTVA = facture.tauxTVA and facture.tauxTVA > 0 %}

        {% set totalRemise = 0 %}
        {% set totalTVA = 0 %}
        {% set totalTTC = 0 %}
        {% set totalHTApresRemise = 0 %}

        <table class="bordered" style="font-size:11px;">
            <thead>
                <tr>
                    <th>Type de Prestation</th>
                    <th style="text-align:center;">Agents</th>
                    <th style="text-align:center;">Jour</th>
                    <th style="text-align:center;">Nuit</th>
                    <th style="text-align:right;">Tarif / Agent</th>

                    {% if hasRemise %}
                        <th style="text-align:right;">Remise {{ facture.remisePourcentage }}%</th>
                    {% endif %}

                    {% if hasTVA %}
                        <th style="text-align:right;">TVA {{ facture.tauxTVA }}%</th>
                    {% endif %}

                    <th style="text-align:right;">Montant TTC</th>
                </tr>
            </thead>

            <tbody>
                

                {% set tauxProrata = prorata.taux %}


                {# =================== TYPES PRINCIPAUX =================== #}
                {% for ligne in calc.lignes %}
                    {% if ligne.categorie == 'principal' %}

                        <tr>
                            <td>{{ ligne.type }}</td>

                            <td style="text-align:center;">
                                {{ ligne.agentsTotal }}
                            </td>

                            <td style="text-align:center;">
                                {{ ligne.agentsJour }}
                            </td>

                            <td style="text-align:center;">
                                {{ ligne.agentsNuit }}
                            </td>

                            <td style="text-align:right;">
                                {{ ligne.tarif|number_format(0,'.',' ') }}
                            </td>

                            {% if calc.remisePourcentage > 0 %}
                                <td style="text-align:right;">
                                    -{{ ligne.remise|number_format(0,'.',' ') }}
                                </td>
                            {% endif %}

                            {% if calc.tauxTVA > 0 %}
                                <td style="text-align:right;">
                                    {{ ligne.tva|number_format(0,'.',' ') }}
                                </td>
                            {% endif %}

                            <td style="text-align:right;">
                                {{ ligne.ttc|number_format(0,'.',' ') }}
                            </td>

                        </tr>

                    {% endif %}
                {% endfor %}

                {# =================== CONTRATS COMPLÉMENTAIRES =================== #}
                {% set currentCC = null %}

                {% for ligne in calc.lignes %}
                    {% if ligne.categorie == 'complementaire' %}

                        {% if currentCC != ligne.contratComplementaireId %}
                            {% set currentCC = ligne.contratComplementaireId %}

                            <tr style="background:#e3f0ff; font-weight:bold; text-align:center; color:#0d47a1;">
                                <td colspan="6">
                                    Contrat Complémentaire #{{ ligne.contratComplementaireId }}
                                    — {{ ligne.dateDebut|date('d/m/Y') }}
                                    {% if ligne.dateFin %} → {{ ligne.dateFin|date('d/m/Y') }}{% endif %}
                                    — Motif : {{ ligne.motif }}
                                </td>
                            </tr>

                        {% endif %}

                        <tr>
                            <td>{{ ligne.type }}</td>

                            <td style="text-align:center;">
                                {{ ligne.agentsTotal }}
                            </td>

                            <td style="text-align:center;">—</td>
                            <td style="text-align:center;">—</td>

                            <td style="text-align:right;">
                                {{ ligne.tarif|number_format(0,'.',' ') }}
                            </td>

                            {% if calc.remisePourcentage > 0 %}
                                <td style="text-align:right;">
                                    -{{ ligne.remise|number_format(0,'.',' ') }}
                                </td>
                            {% endif %}

                            {% if calc.tauxTVA > 0 %}
                                <td style="text-align:right;">
                                    {{ ligne.tva|number_format(0,'.',' ') }}
                                </td>
                            {% endif %}

                            <td style="text-align:right;">
                                {{ ligne.ttc|number_format(0,'.',' ') }}
                            </td>
                        </tr>

                    {% endif %}
                {% endfor %}

                {# <tr class="total-row">
                    <td colspan="5" style="text-align:right;">
                        TOTAL :
                    </td>

                    <td style="text-align:right;">
                        {{ calc.ttc|number_format(0,'.',' ') }}
                    </td>
                </tr> #}

            </tbody>
        </table>

    {% else %}
        {% include "logescom/comptable/facture/facture_pdf_horaire.html.twig" %}
    {% endif %}

{% endfor %}

{# =================== TOTAUX GÉNÉRAUX (HORS BOUCLE) =================== #}
{% set reste_global = total_global_ttc - total_global_paye %}

<h2>Récapitulatif général</h2>

<table class="bordered">
    <tbody>
        <tr class="total-row">
            <td style="text-align:right;">TOTAL GÉNÉRAL TTC</td>
            <td style="text-align:right;">{{ total_global_ttc|number_format(0,'.',' ') }}</td>
        </tr>

        <tr class="total-row">
            <td style="text-align:right;">MONTANT PAYÉ</td>
            <td style="text-align:right;">{{ total_global_paye|number_format(0,'.',' ') }}</td>
        </tr>

        <tr class="total-row">
            <td style="text-align:right;">RESTE À PAYER</td>
            <td style="text-align:right; color:#d00;">{{ reste_global|number_format(0,'.',' ') }}</td>
        </tr>
    </tbody>
</table>

<!-- =================== MONTANT EN LETTRES =================== -->
<div class="montant-lettres">
    <strong>Arrêté la présente facture à la somme de :</strong><br>
    <u><strong>{{ total_global_ttc|en_lettres }} francs guinéens</strong></u>.
</div>

<!-- ===================== INFORMATIONS BANQUES ===================== -->
{% if banques is not empty %}
    <h2>Informations de paiement</h2>
    <table class="bordered">
        <thead>
            <tr><th>Banque</th><th>Compte</th><th>Type</th></tr>
        </thead>
        <tbody>
        {% for b in banques %}
            <tr>
                <td>{{ b.nom }}</td>
                <td>{{ b.numero ?: '—' }}</td>
                <td>{{ b.type|capitalize }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}

<!-- ===================== FOOTER ===================== -->
<div class="footer">
    Facture imprimée par {{ app.user.prenom }} {{ app.user.nom }} — {{ "now"|date("d/m/Y H:i") }}
</div>
