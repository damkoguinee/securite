{% extends 'base_comptable.html.twig' %}

{% block title %}🧾 Détail de la facture{% endblock %}

{% block presentation %}
<div class="container-fluid px-3">

    <div class="row">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

        <div class="col-sm-12 col-md-10">
            {% include "_common/_messages_flash.html.twig" %}

            <div class="card shadow-lg border-0 mb-4">

                <!-- 🔹 En-tête -->
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-3 mb-md-0">
                        <i class="fa fa-file-invoice-dollar text-warning me-2"></i> Détail de la facture
                    </h5>

                    <div class="d-flex flex-wrap gap-2">

                        <a href="{{ path('app_logescom_comptable_facture_index', { site : site.id }) }}"
                           class="btn btn-outline-light btn-sm shadow-sm">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>

                        <!-- PDF -->
                        <a target="_blank"
                           href="{{ path('app_logescom_comptable_facture_pdf', {site: site.id, facture: facture.id, }) }}"
                           class="btn btn-warning btn-sm shadow-sm">
                            <i class="fa fa-file-pdf me-1"></i> Facture PDF
                        </a>

                        <!-- 🔵 Recouvrement -->
                        <a href="{{ path('app_logescom_comptable_paiement_new', {id: facture.id, site: site.id}) }}"
                           class="btn btn-primary btn-sm shadow-sm">
                            <i class="fa fa-hand-holding-usd me-1"></i> Recouvrement
                        </a>

                        {% if is_granted('ROLE_SUPPRESSION') and facture.paiements|length == 0 %}
                            {{ include('logescom/comptable/facture/_delete_form.html.twig') }}
                        {% endif %}

                    </div>
                </div>

                <!-- 📋 Corps -->
                <div class="card-body bg-light">
                    <div class="table-responsive mb-4">
                        <table class="table table-striped table-hover align-middle shadow-sm">
                            <tbody>

                                <!-- Référence -->
                                <tr>
                                    <th class="bg-secondary text-white w-25">Référence</th>
                                    <td class="fw-bold">{{ facture.reference }}</td>
                                </tr>

                                <!-- Contrat / Bien -->
                                <tr>
                                    <th class="bg-secondary text-white">Contrat</th>
                                    <td>
                                        <i class="fa fa-file-contract text-primary me-2"></i>
                                        N° {{ facture.contrat.id }} —
                                        <strong>{{ facture.contrat.bien.nom|capitalize }} — {{ facture.contrat.bien.client.nomComplet|capitalize }}</strong>
                                    </td>
                                </tr>

                                <!-- Client -->
                                <tr>
                                    <th class="bg-secondary text-white">Client</th>
                                    <td>
                                        {% if facture.contrat.bien.client is defined %}
                                            <i class="fa fa-user text-primary me-2"></i>
                                            {{ facture.contrat.bien.client.prenom|capitalize }}
                                            {{ facture.contrat.bien.client.nom|upper }}
                                        {% else %}
                                            <span class="text-muted">Non renseigné</span>
                                        {% endif %}
                                    </td>
                                </tr>

                                <!-- 📌 MONTANTS FINANCIERS COMPLETS -->
                                <tr>
                                    <th class="bg-dark text-white">Montant HT</th>
                                    <td class="fw-bold">
                                        {{ facture.montantHT|number_format(0, '.', ' ') }} GNF
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-dark text-white">Remise (%)</th>
                                    <td>
                                        {{ facture.remisePourcentage ?? 0 }} %
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-dark text-white">Remise (Montant)</th>
                                    <td>
                                        {{ facture.remiseMontant|number_format(0, '.', ' ') }} GNF
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-dark text-white">Base TVA (HT remise)</th>
                                    <td>
                                        {{ facture.baseTVA|number_format(0, '.', ' ') }} GNF
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-dark text-white">Taux TVA</th>
                                    <td>
                                        {{ facture.tauxTVA }} %
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-dark text-white">Montant TVA</th>
                                    <td>
                                        {{ facture.montantTVA|number_format(0, '.', ' ') }} GNF
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Montant TTC</th>
                                    <td class="fw-bold text-success">
                                        {{ facture.montantTotal|number_format(0, '.', ' ') }} GNF
                                    </td>
                                </tr>

                                <!-- Payé / Reste -->
                                <tr>
                                    <th class="bg-secondary text-white">Montant payé</th>
                                    <td class="fw-bold text-primary">
                                        {{ facture.montantPaye|number_format(0, '.', ' ') }} GNF
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Reste</th>
                                    <td class="fw-bold text-danger">
                                        {{ (facture.montantTotal - facture.montantPaye)|number_format(0, '.', ' ') }} GNF
                                    </td>
                                </tr>

                                <!-- Statut -->
                                <tr>
                                    <th class="bg-secondary text-white">Statut</th>
                                    <td>
                                        {% if facture.statut == 'payee' %}
                                            <span class="badge bg-success">Payée</span>
                                        {% elseif facture.statut == 'en_attente' %}
                                            <span class="badge bg-warning text-dark">En attente</span>
                                        {% else %}
                                            <span class="badge bg-danger">Impayée</span>
                                        {% endif %}
                                    </td>
                                </tr>

                                <!-- Dates -->
                                <tr>
                                    <th class="bg-secondary text-white">Date émission</th>
                                    <td>{{ facture.dateEmission|date('d/m/Y H:i') }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Date échéance</th>
                                    <td>{{ facture.dateEcheance|date('d/m/Y') }}</td>
                                </tr>

                                <!-- Période -->
                                <tr>
                                    <th class="bg-secondary text-white">Période facturée</th>
                                    <td>
                                        Du <strong>{{ facture.periodeDebut|date('d/m/Y') }}</strong>
                                        au <strong>{{ facture.periodeFin|date('d/m/Y') }}</strong>
                                    </td>
                                </tr>

                                <!-- Commentaire -->
                                <tr>
                                    <th class="bg-secondary text-white">Commentaire</th>
                                    <td>{{ facture.commentaire ?: '—' }}</td>
                                </tr>

                                <!-- Date saisie -->
                                <tr>
                                    <th class="bg-secondary text-white">Date de saisie</th>
                                    <td>{{ facture.dateSaisie|date('d/m/Y H:i') }}</td>
                                </tr>

                                <!-- Saisi par -->
                                <tr>
                                    <th class="bg-secondary text-white">Saisi par</th>
                                    <td>
                                        <i class="fa fa-user-check text-primary me-2"></i>
                                        {{ facture.saisiePar.prenom|capitalize }} {{ facture.saisiePar.nom|upper }}
                                    </td>
                                </tr>

                            </tbody>
                        </table>
                    </div>

                    <!-- liste des paiements si existent -->

                    <!-- 🔵 Paiements liés -->
                    {% if facture.paiements|length > 0 %}
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-primary text-white">
                                <i class="fa fa-hand-holding-usd me-2"></i>
                                Paiements liés à cette facture
                            </div>

                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Date</th>
                                                <th>Montant</th>
                                                <th>Mode</th>
                                                <th>Référence</th>
                                                <th width="120">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for paiement in facture.paiements %}
                                                <tr>
                                                    <td>{{ paiement.dateOperation|date('d/m/Y H:i') }}</td>
                                                    <td class="fw-bold text-success">
                                                        {{ paiement.montant|number_format(0, '.', ' ') }} GNF
                                                    </td>
                                                    <td>{{ paiement.modePaie.nom ?? '—' }}</td>
                                                    <td>{{ paiement.reference ?? '—' }}</td>

                                                    <td>
                                                        <div class="d-flex justify-content-between mx-1">
                                                            <a href="{{ path('app_logescom_comptable_paiement_show', {id: paiement.id, site: site.id}) }}"
                                                            class="btn btn-sm btn-outline-primary">
                                                                <i class="fa fa-eye"></i>
                                                            </a>

                                                            {% if is_granted('ROLE_SUPPRESSION') %}
                                                                {{ include('logescom/comptable/paiement/_delete_form.html.twig', { iconOnly: true }) }}
                                                            {% endif %}

                                                        </div>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    {% endif %}


                    <!-- 🧾 Actions bas -->
                    <div class="d-flex justify-content-between flex-wrap">

                        <a class="btn btn-outline-dark btn-sm shadow-sm"
                           href="{{ path('app_logescom_comptable_facture_index', { site : site.id }) }}">
                            <i class="fa fa-arrow-left me-1"></i> Retour
                        </a>

                        <div class="d-flex gap-2">

                            <a href="{{ path('app_logescom_comptable_facture_new', {id: facture.id, site: site.id}) }}"
                               class="btn btn-primary btn-sm shadow-sm">
                                <i class="fa fa-hand-holding-usd me-1"></i> Recouvrement
                            </a>

                            {% if is_granted('ROLE_SUPPRESSION') and facture.paiements|length == 0 %}
                                {{ include('logescom/comptable/facture/_delete_form.html.twig') }}
                            {% elseif facture.paiements|length > 0 %}
                                <span class="badge bg-warning text-dark">
                                    Suppression impossible : paiements associés
                                </span>
                            {% endif %}


                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
