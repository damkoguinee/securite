{% extends 'base_comptable.html.twig' %}

{% block title %}Génération des factures{% endblock %}

{% block presentation %}
<div class="row m-0 p-0">

    {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

    <div class="col-sm-12 col-md-10 m-0 p-0">

        {{ include("_common/_messages_flash.html.twig") }}

        <div class="container my-4">
            <div class="row justify-content-center">
                <div class="col-sm-12 col-md-10">

                    <!-- 🏷️ En-tête -->
                    <div class="text-center mb-4">
                        <h4 class="fw-bold text-primary">
                            <i class="fa fa-file-invoice-dollar me-2"></i>
                            Générer les factures d'un mois donné
                        </h4>
                        <p class="text-muted">
                            Sélectionnez la période à facturer puis validez pour lancer la génération.
                        </p>
                    </div>

                    <!-- 🗂️ Liste des mois -->
                    {% set mois = {
                        1: 'Janvier',
                        2: 'Février',
                        3: 'Mars',
                        4: 'Avril',
                        5: 'Mai',
                        6: 'Juin',
                        7: 'Juillet',
                        8: 'Août',
                        9: 'Septembre',
                        10: 'Octobre',
                        11: 'Novembre',
                        12: 'Décembre'
                    } %}

                    <!-- 🧾 Carte principale -->
                    <div class="card border-0 shadow-lg rounded-3">
                        <div class="card-body p-4 bg-light">

                            <form id="form-generate" method="post"
                                  action="{{ path('app_logescom_comptable_facture_new', {'site': site.id}) }}">

                                <div class="row g-3 mb-4">

                                    <!-- 📅 Mois -->
                                    <div class="col-md-3">
                                        <label class="form-label fw-semibold">Mois *</label>
                                        <select name="mois" id="select-mois"
                                                class="form-select shadow-sm" required>
                                            <option value="">Sélectionnez un mois</option>
                                            {% for key, nom in mois %}
                                                <option value="{{ key }}">{{ nom }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    <!-- 📆 Année -->
                                    <div class="col-md-3">
                                        <label class="form-label fw-semibold">Année *</label>
                                        <select name="annee" id="select-annee"
                                                class="form-select shadow-sm" required>
                                            <option value="">Sélectionnez une année</option>
                                            {% for y in 2022..("now"|date("Y") + 1) %}
                                                <option value="{{ y }}"
                                                    {% if y == "now"|date("Y") %} selected {% endif %}>
                                                    {{ y }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    <!-- 👤 Client -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold">Clients</label>
                                        <select name="client" class="form-select shadow-sm">
                                            <option value="">Sélectionnez un client</option>
                                            {% for client in clients %}
                                                <option value="{{ client.id }}">
                                                    {{ client.nomComplet }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                </div>

                                <!-- 🔘 Bouton Générer -->
                                <div class="text-center mt-4">
                                    <button type="button"
                                            class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#confirmModal">
                                        <i class="fa fa-cogs me-2"></i>
                                        Générer les factures
                                    </button>
                                </div>

                            </form>

                            <hr class="my-4">

                            <!-- 🔙 Retour -->
                            <div>
                                <a href="{{ path('app_logescom_comptable_facture_index', {'site': site.id}) }}"
                                   class="btn btn-outline-secondary">
                                    <i class="fa fa-arrow-left me-1"></i>
                                    Retour à la liste
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- 🟦 MODAL DE CONFIRMATION -->
        <div class="modal fade" id="confirmModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content shadow-lg">

                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">
                            <i class="fa fa-exclamation-circle me-2"></i>
                            Confirmation de génération
                        </h5>
                        <button type="button" class="btn-close btn-close-white"
                                data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body text-center">
                        <p class="fs-5">
                            Voulez-vous vraiment générer les factures
                            pour la période sélectionnée ?
                        </p>
                        <p class="text-muted">
                            ⚠️ Veuillez vérifier les informations avant de continuer.
                        </p>
                    </div>

                    <div class="modal-footer justify-content-between">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Annuler
                        </button>

                        <button type="submit" form="form-generate"
                                class="btn btn-primary px-4 rounded-pill">
                            <i class="fa fa-check-circle me-1"></i>
                            Confirmer
                        </button>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<!-- 🔵 SCRIPT FILTRAGE DYNAMIQUE -->
<script>
document.addEventListener('DOMContentLoaded', function () {

    const selectAnnee = document.getElementById('select-annee');
    const selectMois  = document.getElementById('select-mois');

    const today = new Date();
    const anneeActuelle = today.getFullYear();
    const moisActuel    = today.getMonth() + 1;

    function filtrerMois() {

        const anneeSelectionnee = parseInt(selectAnnee.value);

        Array.from(selectMois.options).forEach(option => {

            const moisOption = parseInt(option.value);
            if (!moisOption) return;

            if (anneeSelectionnee < anneeActuelle) {
                option.hidden = false;
            }
            else if (anneeSelectionnee === anneeActuelle) {
                option.hidden = moisOption > moisActuel;
            }
            else {
                option.hidden = true;
            }
        });

        if (anneeSelectionnee === anneeActuelle) {
            selectMois.value = moisActuel;
        } else {
            selectMois.value = "";
        }
    }

    selectAnnee.addEventListener('change', filtrerMois);
    filtrerMois();
});
</script>

{% endblock %}