{% extends 'base_comptable.html.twig' %}

{% block title %}💰 Détail du décaissement{% endblock %}

{% block presentation %}
<div class="container-fluid px-3">
    {% include "_common/_messages_flash.html.twig" %}

    <div class="row">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

        <div class="col-sm-12 col-md-10">
            <div class="card shadow-lg border-0 mb-4">
                <!-- 🔹 En-tête -->
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-3 mb-md-0">
                        <i class="fa fa-wallet text-warning me-2"></i> Détail du décaissement
                    </h5>

                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('app_logescom_comptable_sorties_decaissement_index', { site : site.id}) }}"
                           class="btn btn-outline-light btn-sm shadow-sm">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>

                        {% if is_granted("ROLE_MODIFICATION") %}
                            <a href="{{ path('app_logescom_comptable_sorties_decaissement_edit', {'id': decaissement.id, site : site.id}) }}"
                               class="btn btn-warning btn-sm shadow-sm">
                                <i class="fa fa-edit me-1"></i> Modifier
                            </a>
                        {% endif %}

                        {% if is_granted("ROLE_SUPPRESSION") %}
                            <div class="text-end">
                                {{ include('logescom/comptable/sorties/decaissement/_delete_form.html.twig', {
                                    'button_label': '<i class="fa fa-trash"></i> Supprimer',
                                    'button_class': 'btn btn-danger btn-sm shadow-sm'
                                }) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- 📋 Corps -->
                <div class="card-body bg-light">
                    <div class="table-responsive mb-4">
                        <table class="table table-striped table-hover align-middle shadow-sm">
                            <tbody>
                                <tr>
                                    <th class="bg-secondary text-white w-25">Référence</th>
                                    <td class="fw-semibold">{{ decaissement.reference }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Collaborateur</th>
                                    <td>
                                        <i class="fa fa-user text-primary me-2"></i>
                                        {{ decaissement.collaborateur.prenom|capitalize }} {{ decaissement.collaborateur.nom|upper }}
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Motif</th>
                                    <td>{{ decaissement.commentaire|default('—')|capitalize }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Montant</th>
                                    <td class="fw-bold  text-success">
                                        {% if decaissement.devise.nom == 'gnf' %}
                                            {{ decaissement.montant|abs|number_format(0, '.', ' ') }} GNF
                                        {% else %}
                                            {{ decaissement.montant|abs|number_format(2, ',', ' ') }} {{ decaissement.devise.nom|upper }}
                                        {% endif %}
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Devise</th>
                                    <td>{{ decaissement.devise.nom|upper }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Mode de paiement</th>
                                    <td>{{ decaissement.modePaie.designation|capitalize }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Numéro paiement</th>
                                    <td>{{ decaissement.bordereau ?: '—' }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Caisse de retrait</th>
                                    <td>{{ decaissement.caisse.nom|capitalize }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Date du décaissement</th>
                                    <td>{{ decaissement.dateOperation ? decaissement.dateOperation|date('d/m/Y H:i') : '—' }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white"><i class="fas fa-file-pdf text-danger me-1"></i>Document</th>
                                    <td>
                                        {% if decaissement.document %}
                                            <a href="{{ asset(chemin_decaissements ~ decaissement.document) }}" target="_blank"
                                               class="btn btn-sm btn-outline-primary shadow-sm">
                                                <i class="fas fa-file-pdf me-1"></i> Voir le document
                                            </a>
                                        {% else %}
                                            <span class="text-muted">Aucun document disponible</span>
                                        {% endif %}
                                    </td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Date de saisie</th>
                                    <td>{{ decaissement.dateSaisie ? decaissement.dateSaisie|date('d/m/Y H:i') : '—' }}</td>
                                </tr>

                                <tr>
                                    <th class="bg-secondary text-white">Saisi par</th>
                                    <td>
                                        {{ decaissement.saisiePar.prenom|capitalize }} {{ decaissement.saisiePar.nom|upper }}
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- 🧾 Actions supplémentaires -->
                    <div class="d-flex justify-content-between flex-wrap">
                        <a class="btn btn-outline-dark btn-sm shadow-sm"
                           href="{{ path('app_logescom_comptable_sorties_decaissement_index', { site : site.id}) }}">
                            <i class="fa fa-arrow-left me-1"></i> Retour
                        </a>

                        <div class="d-flex gap-2">
                            <a target="_blank"
                               href="{{ path('app_logescom_comptable_sorties_decaissement_recu_pdf', {'id': decaissement.id, 'site': site.id}) }}"
                               class="btn btn-sm btn-outline-danger shadow-sm">
                               <i class="fa fa-file-pdf me-1"></i> Reçu PDF
                            </a>

                            {% if is_granted("ROLE_MODIFICATION") %}
                                <a class="btn btn-sm btn-warning shadow-sm"
                                   href="{{ path('app_logescom_comptable_sorties_decaissement_edit', {'id': decaissement.id, site : site.id}) }}">
                                   <i class="fa fa-edit me-1"></i> Modifier
                                </a>
                            {% endif %}

                            {% if is_granted("ROLE_SUPPRESSION") %}
                                {{ include('logescom/comptable/sorties/decaissement/_delete_form.html.twig', {
                                    'button_label': '<i class="fa fa-trash"></i> Supprimer',
                                    'button_class': 'btn btn-danger btn-sm shadow-sm'
                                }) }}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
