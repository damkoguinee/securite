<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Reçu de Décaissement - {{ decaissement.reference|upper }}</title>

    {% block stylesheets %}
        <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css">
    {% endblock %}

    <style>
        body {
            font-family: "Helvetica", Arial, sans-serif;
            color: #333;
            margin: 20px 40px;
            font-size: 14px;
        }

        /* 🔹 En-tête */
        .header {
            text-align: center;
            border-bottom: 2px solid #000;
            padding-bottom: 8px;
            margin-bottom: 20px;
        }

        .header img {
            width: 180px; /* ✅ Logo plus petit */
            height: auto;
        }

        .header .infos {
            margin-top: 8px;
            font-size: 13px;
            line-height: 1.3;
        }

        /* 🔹 Titres */
        h1 {
            font-size: 18px;
            font-weight: bold;
            text-transform: uppercase;
            text-align: center;
            color: #000;
            margin-bottom: 15px;
        }

        /* 🔹 Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
        }

        th, td {
            padding: 7px;
            vertical-align: middle;
        }

        th {
            background-color: #f8f9fa;
            text-align: left;
            font-weight: 600;
        }

        td {
            border-bottom: 1px solid #ddd;
        }

        .amount {
            font-weight: bold;
            color: #0d6efd;
            font-size: 16px;
        }

        /* 🔹 Sections */
        .section-title {
            background-color: #f2f2f2;
            padding: 6px 8px;
            font-weight: bold;
            border-left: 3px solid #0d6efd;
            margin-top: 25px;
            font-size: 15px;
        }

        /* 🔹 Signatures */
        .signatures {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 60px;
        }

        .signature-block {
            text-align: center;
            width: 45%;
        }

        .signature-line {
            margin-top: 60px;
            border-top: 1px solid #000;
            width: 80%;
            margin-left: auto;
            margin-right: auto;
        }

        /* 🔹 Pied de page */
        .footer {
            font-size: 13px;
            color: #555;
            border-top: 1px solid #ddd;
            padding-top: 6px;
            margin-top: 30px;
            text-align: right;
            font-style: italic;
        }

        /* 🔹 Centrage texte */
        .text-center {
            text-align: center;
        }

    </style>
</head>

<body>
    <!-- 🧾 En-tête -->
    <div class="header">
        <img src="data:image/jpeg;base64,{{ logoPath }}" alt="Logo">
        <div class="infos">
            <div><strong>{{ site.entreprise.nom|upper }}</strong></div>
            <div>{{ site.adresse.nom }} — Tél : {{ site.telephone }}</div>
            <div>{{ site.entreprise.numeroAgrement }}</div>
        </div>
    </div>

    <h1>Reçu de Décaissement</h1>

    <!-- 🔸 Informations principales -->
    <table>
        <tr>
            <th>Reçu N°</th>
            <td><strong>{{ decaissement.reference|upper }}</strong></td>
            <th>Date</th>
            <td>{{ decaissement.dateOperation|date("d/m/Y") }}</td>
        </tr>
        <tr>
            <th>Collaborateur</th>
            <td>{{ decaissement.collaborateur.prenom|ucwords }} {{ decaissement.collaborateur.nom|upper }}</td>
            <th>Téléphone</th>
            <td>{{ decaissement.collaborateur.telephone }}</td>
        </tr>
        <tr>
            <th>Adresse</th>
            <td colspan="3">{{ decaissement.collaborateur.adresse.nom|capitalize }}</td>
        </tr>
    </table>

    <!-- 🔸 Détails financiers -->
    <div class="section-title">Détails du décaissement</div>
    <table>
        <tr>
            <th>Mode de paiement</th>
            <td>{{ decaissement.modePaie.designation|capitalize }}</td>
            <th>Caisse de retrait</th>
            <td>{{ decaissement.caisse.nom|capitalize }}</td>
        </tr>
        <tr>
            <th>Montant décaissé</th>
            <td class="amount" colspan="3">
                {{ decaissement.devise.nom == 'gnf'
                    ? decaissement.montant|abs|number_format(0,',',' ')
                    : decaissement.montant|abs|number_format(2,',',' ') }}
                {{ decaissement.devise.nom|upper }}
            </td>
        </tr>
        <tr>
            <th>Motif</th>
            <td colspan="3">{{ decaissement.commentaire|capitalize }}</td>
        </tr>
    </table>

    <!-- 🔸 Soldes -->
    <div class="section-title">Ancien solde</div>
    <table>
        <tr>
            {% for solde in ancien_solde %}
                <td>
                    {{ solde.devise|upper }} :
                    {{ solde.devise == 'gnf'
                        ? solde.montant|abs|number_format(0,',',' ')
                        : solde.montant|abs|number_format(2,',',' ') }}
                </td>
            {% endfor %}
        </tr>
    </table>

    <div class="section-title">Solde actuel au {{ "now"|date("d/m/Y H:i") }}</div>
    <table>
        <tr>
            {% for solde in solde_collaborateur %}
                <td>
                    {{ solde.devise|upper }} :
                    {{ solde.devise == 'gnf'
                        ? solde.montant|abs|number_format(0,',',' ')
                        : solde.montant|abs|number_format(2,',',' ') }}
                </td>
            {% endfor %}
        </tr>
    </table>

    <!-- 🔸 Résumé -->
    <p class="mt-4">
        À la date du <strong>{{ "now"|date("d/m/Y") }}</strong>,
        {% for key, solde in solde_collaborateur %}
            {% if key == 0 %}
                {% if solde.montant > 0 %}
                    nous vous devons <strong>{{ solde.montant|abs|number_format(0,',',' ') }} {{ solde.devise|upper }}</strong>.
                {% else %}
                    vous nous devez <strong>{{ (-solde.montant)|number_format(0,',',' ') }} {{ solde.devise|upper }}</strong>.
                {% endif %}
            {% endif %}
        {% endfor %}
    </p>

    <p class="text-center mt-3">************** {{ site.entreprise.nom|upper }} vous souhaite une excellente journée **************</p>

    <!-- 🔸 Signatures -->
    <table style="width:100%; margin-top:1px; text-align:center;">
        <tr>
            <th style="width:50%; text-align:center;">Le Gestionnaire</th>
            <th style="width:50%; text-align:center;">Le Collaborateur</th>
        </tr>
        <tr>
            <td style="padding-top:60px; border-top:1px solid #000; font-weight:bold;">
                {{ decaissement.saisiePar.prenom|ucwords }} {{ decaissement.saisiePar.nom|upper }}
            </td>
            <td style="padding-top:60px; border-top:1px solid #000; font-weight:bold;">
                {{ decaissement.collaborateur.prenom|ucwords }} {{ decaissement.collaborateur.nom|upper }}
            </td>
        </tr>
    </table>


    <!-- 🔸 Pied de page -->
    <div class="footer">
        Reçu imprimé par {{ app.user.prenom|ucwords }} {{ app.user.nom|upper }}
        le {{ "now"|date("d/m/Y à H:i") }}
    </div>
</body>
</html>
