{% extends 'base_comptable.html.twig' %}

{% block title %}Nouveau décaissement{% endblock %}

{% block presentation %}
<div class="row m-0 p-0">
    <!-- 🧭 Navigation latérale -->
    {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

    <!-- 🧾 Contenu principal -->
    <div class="col-sm-12 col-md-10 m-0 p-0">
        {{ include("_common/_messages_flash.html.twig") }}

        <div class="container my-4">
            <div class="row justify-content-center">
                <div class="col-sm-12 col-md-11">

                    <!-- 🏷️ En-tête -->
                    <div class="text-center mb-4">
                        <h4 class="fw-bold text-primary">
                            <i class="fa fa-wallet me-2"></i> Nouveau décaissement
                        </h4>
                        <p class="text-muted mb-0">
                            Veuillez renseigner les informations relatives au décaissement avant d’enregistrer.
                        </p>
                    </div>

                    <!-- 🧾 Carte principale -->
                    <div class="card border-0 shadow-lg rounded-3">
                        <div class="card-body p-4 bg-light">

                            <!-- 👤 Sélection du collaborateur -->
                            {% if app.request.query.has('id_client_search') %}
                                {% set collaborateur = app.request.query.get('id_client_search') %}
                            {% else %}
                                {% set collaborateur = "" %}
                            {% endif %}

                            {% set client_find = client_find is not empty
                                ? (client_find.prenom|ucwords ~ " " ~ client_find.nom|upper ~ " - " ~ client_find.telephone)
                                : "Recherchez un collaborateur..."
                            %}

                            {% include "_common/_solde_collaborateur.html.twig" %}

                            <div class="mb-3">
                                <input type="text" name="search" id="search_client"
                                       class="form-control shadow-sm rounded-pill"
                                       placeholder="{{ client_find }}">
                                <div id="result-search"
                                     class="bg-white text-danger fw-bold py-2 mt-1 rounded small"></div>
                            </div>

                            <!-- 🧍‍♂️ Formulaire principal -->
                            {{ include('logescom/comptable/sorties/decaissement/_form.html.twig', {'button_label': 'Enregistrer'}) }}

                            <hr class="my-4">

                            <!-- 🔙 Bouton retour -->
                            <div class="d-flex justify-content-between align-items-center">
                                <a href="{{ path('app_logescom_comptable_sorties_decaissement_index', {'site': site.id}) }}"
                                   class="btn btn-outline-secondary">
                                    <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
