{{ form_errors(form) }}
{{ form_start(form) }}

<input type="hidden" name="collaborateur" value="{{ collaborateur }}">

<div class="row">
    <div class="col-md-4 mb-3">
        {{ form_row(form.dateOperation, {
            label: '📅 Date du décaissement *'
        }) }}
    </div>

    <div class="col-md-4 mb-3">
        {{ form_row(form.montant, {
            label: '💰 Montant *',
            attr: {'placeholder': 'Ex : 150000 ou 250.00'}
        }) }}
    </div>

    <div class="col-md-4 mb-3">
        {{ form_row(form.devise, {
            label: '💱 Devise *',
            attr: {'class': 'form-select'}
        }) }}
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        {{ form_row(form.modePaie, {
            label: '🏦 Mode de paiement *',
            attr: {'class': 'form-select'}
        }) }}
    </div>

    <div class="col-md-4 mb-3">
        {{ form_row(form.caisse, {
            label: '💼 Caisse de retrait *',
            attr: {'class': 'form-select'}
        }) }}
    </div>

    <div class="col-md-4 mb-3">
        {{ form_row(form.bordereau, {
            label: '🔢 N° paiement / Bordereau',
            attr: {'placeholder': 'Ex : Chèque 00234, Réf. virement...'}
        }) }}
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        {{ form_row(form.categorie, {
            label: '📂 Catégorie',
            attr: {'class': 'form-select'}
        }) }}
    </div>

    <div class="col-md-5 mb-3">
        {{ form_row(form.commentaire, {
            label: '💬 Motif ou commentaire *',
            attr: {'rows': 2, 'placeholder': 'Décrivez brièvement le motif du décaissement'}
        }) }}
    </div>

    <div class="col-md-3 mb-3">
        {{ form_row(form.document, {
            label: '📎 Pièce jointe',
            attr: {'class': 'form-control'}
        }) }}
    </div>
</div>

<hr class="my-3">

<div class="text-end mt-3">
    <button class="btn btn-primary px-4">
        <i class="bi bi-save me-1"></i> {{ button_label|default('Enregistrer') }}
    </button>
</div>

{{ form_end(form) }}
