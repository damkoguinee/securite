{% extends 'base_comptable.html.twig' %}

{% block title %}💸 Liste des dépenses{% endblock %}

{% block presentation %}
{% if app.request.query.has('date1') %}
            {% set date1 = app.request.query.get('date1') %}
            {% set date2 = app.request.query.get('date2') %}
        {% else %}
            {% set date1 = "now"|date("Y-01-01") %}
            {% set date2 = "now"|date("Y-m-d") %}
        {% endif %}
<div class="container-fluid px-3">
    {% include "_common/_messages_flash.html.twig" %}

    <div class="row">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

        <div class="col-sm-12 col-md-10">
            <div class="card shadow-lg border-0 mb-1">
                <!-- 🔹 En-tête -->
                <div class="card-header bg-dark text-white py-3 px-4 d-flex flex-wrap justify-content-between align-items-center">
                    <h5 class="mb-1 mb-md-0">
                        <i class="fa fa-coins me-2 text-warning"></i> Liste des dépenses
                    </h5>

                    <!-- 🔍 Filtres -->
                    <div class="filters d-flex flex-wrap align-items-center gap-3">
                        <!-- 📅 Filtres dates -->
                        <form class="d-flex align-items-center gap-2 flex-wrap">
                            <div class="d-flex align-items-center gap-2">
                                <label class="fw-semibold text-white mb-0">Du</label>
                                <input type="date" name="date1" value="{{ date1 }}"
                                       class="form-control form-control-sm shadow-sm border-0 rounded-pill"
                                       onchange="this.form.submit()">
                            </div>

                            <div class="d-flex align-items-center gap-2">
                                <label class="fw-semibold text-white mb-0">au</label>
                                <input type="date" name="date2" value="{{ date2 }}"
                                       class="form-control form-control-sm shadow-sm border-0 rounded-pill"
                                       onchange="this.form.submit()">
                            </div>

                            <!-- 📂 Catégorie -->
                            <select name="categorie" class="form-select form-select-sm shadow-sm border-0 rounded-pill"
                                    onchange="this.form.submit()">
                                <option value="{{ search ? search.id : '' }}">
                                    {{ search ? search.nom|ucfirst : 'Catégorie...' }}
                                </option>
                                {% for categorie in categories %}
                                    <option value="{{ categorie.id }}">{{ categorie.nom|capitalize }}</option>
                                {% endfor %}
                            </select>
                        </form>

                        <!-- ➕ Nouveau -->
                        <a href="{{ path('app_logescom_comptable_sorties_depense_new', {site: site.id}) }}"
                           class="btn btn-warning btn-sm rounded-pill shadow-sm">
                            <i class="fa fa-plus-circle me-1"></i> Nouvelle
                        </a>

                        <!-- 📄 Export PDF -->
                        <a target="_blank"
                           href="{{ path('app_logescom_comptable_sorties_depense_pdf', {
                                site: site.id, date1: date1, date2: date2, categorie: search ? search.id : null
                           }) }}"
                           class="btn btn-outline-info btn-sm rounded-pill shadow-sm">
                            <i class="fa fa-file-pdf me-1"></i> Imprimer
                        </a>
                    </div>
                </div>

                <!-- 📋 Contenu principal -->
                <div class="card-body bg-light p-1">
                    {% if depenses.data is not empty %}
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered align-middle shadow-sm">
                                <thead class="table-dark text-center align-middle">
                                    <tr>
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Catégorie</th>
                                        <th>Description</th>
                                        <th>Montant</th>
                                        <th>Devise</th>
                                        <th>Mode de paiement</th>
                                        <th>Caisse</th>
                                        <th>Traité par</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white text-center">
                                    {% for key, depense in depenses.data %}
                                        <tr>
                                            <td class="fw-semibold">
                                                {{ key + 1 }}
                                                {% if depense.document %}
                                                    <a href="{{ asset('depense/' ~ depense.document) }}" target="_blank"
                                                       title="Voir pièce jointe">
                                                        <i class="fa fa-file-pdf text-danger ms-1"></i>
                                                    </a>
                                                {% endif %}
                                            </td>
                                            <td>{{ depense.dateOperation ? depense.dateOperation|date('d/m/Y') : '—' }}</td>
                                            <td>{{ depense.categorieDepense.nom|capitalize }}</td>
                                            <td>{{ depense.commentaire|capitalize }}</td>
                                            <td class="text-end fw-bold">
                                                {% if depense.devise.nom == 'gnf' %}
                                                    {{ depense.montant|abs|number_format(0, '.', ' ') }}
                                                {% else %}
                                                    {{ depense.montant|abs|number_format(2, ',', ' ') }}
                                                {% endif %}
                                            </td>
                                            <td>{{ depense.devise.nom|upper }}</td>
                                            <td>{{ depense.modePaie.designation|capitalize }}</td>
                                            <td>{{ depense.caisse.nom|capitalize }}</td>
                                            <td>{{ depense.saisiePar.prenom|ucwords ~ ' ' ~ depense.saisiePar.nom|upper }}</td>
                                            <td>
                                                <a href="{{ path('app_logescom_comptable_sorties_depense_show', {'id': depense.id, 'site': site.id}) }}"
                                                   class="btn btn-sm btn-outline-success" title="Voir le détail">
                                                    <i class="fa fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="alert alert-secondary text-center my-4">
                            <i class="fa fa-info-circle me-1"></i> Aucune dépense enregistrée pour cette période.
                        </div>
                    {% endif %}

                    <!-- 📄 Pagination -->
                    {% if depenses.nbrePages > 1 %}
                        <nav class="mt-3">
                            <ul class="pagination justify-content-center">
                                <!-- ⬅️ Précédent -->
                                <li class="page-item {{ depenses.pageEnCours == 1 ? 'disabled' : '' }}">
                                    <a class="page-link"
                                       href="{{ path(app.request.attributes.get('_route'),
                                           app.request.query.all | merge({'pageEnCours': depenses.pageEnCours - 1, 'site': site.id})) }}">
                                       &laquo;
                                    </a>
                                </li>

                                {% set start = max(1, depenses.pageEnCours - 2) %}
                                {% set end = min(depenses.nbrePages, depenses.pageEnCours + 2) %}

                                {% if start > 1 %}
                                    <li class="page-item">
                                        <a class="page-link"
                                           href="{{ path(app.request.attributes.get('_route'),
                                               app.request.query.all | merge({'pageEnCours': 1, 'site': site.id})) }}">1</a>
                                    </li>
                                    {% if start > 2 %}
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    {% endif %}
                                {% endif %}

                                {% for i in start..end %}
                                    <li class="page-item {{ i == depenses.pageEnCours ? 'active' : '' }}">
                                        <a class="page-link"
                                           href="{{ path(app.request.attributes.get('_route'),
                                               app.request.query.all | merge({'pageEnCours': i, 'site': site.id})) }}">{{ i }}</a>
                                    </li>
                                {% endfor %}

                                {% if end < depenses.nbrePages %}
                                    {% if end < depenses.nbrePages - 1 %}
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    {% endif %}
                                    <li class="page-item">
                                        <a class="page-link"
                                           href="{{ path(app.request.attributes.get('_route'),
                                               app.request.query.all | merge({'pageEnCours': depenses.nbrePages, 'site': site.id})) }}">
                                           {{ depenses.nbrePages }}
                                        </a>
                                    </li>
                                {% endif %}

                                <!-- ➡️ Suivant -->
                                <li class="page-item {{ depenses.pageEnCours == depenses.nbrePages ? 'disabled' : '' }}">
                                    <a class="page-link"
                                       href="{{ path(app.request.attributes.get('_route'),
                                           app.request.query.all | merge({'pageEnCours': depenses.pageEnCours + 1, 'site': site.id})) }}">
                                       &raquo;
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #result-search {
        max-height: 250px;
        overflow-y: auto;
    }
    #result-search .list-group-item:hover {
        background-color: #f8f9fa;
    }
</style>
{% endblock %}
