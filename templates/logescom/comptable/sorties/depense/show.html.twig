{% extends 'base_comptable.html.twig' %}

{% block title %}💸 Détail de la dépense{% endblock %}

{% block presentation %}
<div class="container-fluid px-3">
    <div class="row">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

        <div class="col-sm-12 col-md-10">
            <div class="card shadow-lg border-0 mb-4">
                <!-- 🔹 En-tête -->
                <div class="card-header bg-dark text-white py-3 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fa fa-receipt me-2 text-warning"></i> Détail de la dépense
                    </h5>

                    <div>
                        <a href="{{ path('app_logescom_comptable_sorties_depense_index', {'site': site.id}) }}"
                           class="btn btn-outline-light btn-sm">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>
                    </div>
                </div>

                <!-- 📋 Corps principal -->
                <div class="card-body bg-light p-4">
                    <div class="table-responsive mb-4">
                        <table class="table table-bordered table-hover align-middle bg-white shadow-sm">
                            <tbody>
                                <tr>
                                    <th class="bg-secondary text-white w-25">Description</th>
                                    <td>{{ depense.commentaire|capitalize }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">Catégorie</th>
                                    <td>{{ depense.categorieDepense.nom|ucwords }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">Montant</th>
                                    <td class="fw-bold">
                                        {% if depense.devise.nom == 'gnf' %}
                                            {{ depense.montant|abs|number_format(0, ',', ' ') }}
                                        {% else %}
                                            {{ depense.montant|abs|number_format(2, ',', ' ') }}
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">Devise</th>
                                    <td>{{ depense.devise.nom|upper }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">Mode de paiement</th>
                                    <td>{{ depense.modePaie.designation|capitalize }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">Compte de retrait</th>
                                    <td>{{ depense.caisse.nom|capitalize }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">
                                        <i class="fas fa-file-pdf text-danger me-1"></i>Document
                                    </th>
                                    <td>
                                        {% if depense.document %}
                                            <a href="{{ asset(chemin_depenses ~ depense.document) }}" target="_blank"
                                               class="btn btn-sm btn-outline-primary rounded-pill shadow-sm">
                                                <i class="fas fa-file-pdf me-1"></i> Voir le document
                                            </a>
                                        {% else %}
                                            <span class="text-muted">Aucun document</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">Date de la dépense</th>
                                    <td>{{ depense.dateOperation ? depense.dateOperation|date('d/m/Y H:i') : '—' }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">Date de saisie</th>
                                    <td>{{ depense.dateSaisie ? depense.dateSaisie|date('d/m/Y H:i') : '—' }}</td>
                                </tr>
                                <tr>
                                    <th class="bg-secondary text-white">Traité par</th>
                                    <td>{{ depense.saisiePar.prenom|ucwords ~ ' ' ~ depense.saisiePar.nom|upper }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- 🔘 Boutons d’action -->
                    <div class="d-flex justify-content-between align-items-center">
                        <a class="btn btn-outline-secondary"
                           href="{{ path('app_logescom_comptable_sorties_depense_index', {'site': site.id}) }}">
                            <i class="fa fa-arrow-left me-1"></i> Retour
                        </a>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_logescom_comptable_sorties_depense_edit', {'id': depense.id, 'site': site.id}) }}"
                               class="btn btn-warning text-white">
                                <i class="fa fa-edit me-1"></i> Modifier
                            </a>

                            <form method="post"
                                  action="{{ path('app_logescom_comptable_sorties_depense_confirm_delete', {'id': depense.id}) }}"
                                  onsubmit="return confirm('Voulez-vous vraiment supprimer cette dépense ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ depense.id) }}">
                                <button class="btn btn-danger">
                                    <i class="fa fa-trash me-1"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
