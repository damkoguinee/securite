{% extends 'base_comptable.html.twig' %}

{% block title %}Modifier configuration salaire{% endblock %}

{% block presentation %}
<div class="row m-0 p-0">
    {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

    <div class="col-sm-12 col-md-10 m-0 p-0">
        {% include "_common/_messages_flash.html.twig" %}

        <div class="card shadow-sm border-0 mb-4">

            <!-- 🔹 Header -->
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fa fa-edit me-2"></i>
                    Modifier une configuration de salaire
                </h5>

                <a href="{{ path(
                    'app_logescom_comptable_salaire_personnel_config_salaire_index',
                    { site: site.id }
                ) }}"
                   class="btn btn-outline-dark btn-sm">
                    <i class="fa fa-arrow-left me-1"></i>
                    Retour
                </a>
            </div>

            <!-- 📋 Formulaire -->
            <div class="card-body bg-light">
                {{ include(
                    'logescom/comptable/salaire_personnel/config_salaire/_form.html.twig',
                    { button_label: 'Mettre à jour' }
                ) }}
            </div>

            {# <!-- 🗑️ Suppression -->
            <div class="card-footer bg-white d-flex justify-content-end">
                {{ include(
                    'logescom/comptable/salaire_personnel/config_salaire/_delete_form.html.twig'
                ) }}
            </div> #}

        </div>
    </div>
</div>
{% endblock %}
