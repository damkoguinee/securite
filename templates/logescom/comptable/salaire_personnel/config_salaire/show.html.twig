{% extends 'base_comptable.html.twig' %}

{% block title %}Détail configuration salaire{% endblock %}

{% block presentation %}
<div class="row m-0 p-0">
    {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

    <div class="col-sm-12 col-md-10 m-0 p-0">
        {% include "_common/_messages_flash.html.twig" %}

        <div class="card shadow-sm border-0 mb-4">

            <!-- 🔹 Header -->
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fa fa-eye me-2"></i>
                    Détail configuration salaire
                </h5>

                <div class="d-flex gap-2">
                    <a href="{{ path(
                        'app_logescom_comptable_salaire_personnel_config_salaire_index',
                        { site: site.id }
                    ) }}"
                       class="btn btn-outline-light btn-sm">
                        <i class="fa fa-arrow-left me-1"></i>
                        Retour
                    </a>

                    <a href="{{ path(
                        'app_logescom_comptable_salaire_personnel_config_salaire_edit',
                        { id: config_salaire.id, site: site.id }
                    ) }}"
                       class="btn btn-warning btn-sm">
                        <i class="fa fa-edit me-1"></i>
                        Modifier
                    </a>
                </div>
            </div>

            <!-- 📋 Contenu -->
            <div class="card-body bg-light">

                <table class="table table-borderless table-sm mb-0">
                    <tbody>
                        <tr>
                            <th class="text-muted w-25">Code</th>
                            <td class="fw-bold text-primary">
                                {{ config_salaire.code }}
                            </td>
                        </tr>

                        <tr>
                            <th class="text-muted">Libellé</th>
                            <td>{{ config_salaire.libelle }}</td>
                        </tr>

                        <tr>
                            <th class="text-muted">Type</th>
                            <td>
                                <span class="badge bg-info">
                                    {{ config_salaire.type|capitalize }}
                                </span>
                            </td>
                        </tr>

                        <tr>
                            <th class="text-muted">Taux</th>
                            <td>
                                {{ config_salaire.taux is not null
                                    ? config_salaire.taux ~ ' %'
                                    : '—'
                                }}
                            </td>
                        </tr>

                        <tr>
                            <th class="text-muted">Montant</th>
                            <td>
                                {{config_salaire.montant|number_format(0,',',' ')}}
                            </td>
                        </tr>

                        <tr>
                            <th class="text-muted">Statut</th>
                            <td>
                                {% if config_salaire.actif %}
                                    <span class="badge bg-success">
                                        Actif
                                    </span>
                                {% else %}
                                    <span class="badge bg-danger">
                                        Inactif
                                    </span>
                                {% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>

            </div>

            <!-- 🗑️ Suppression -->
            <div class="card-footer bg-white d-flex justify-content-end">
                {{ include(
                    'logescom/comptable/salaire_personnel/config_salaire/_delete_form.html.twig'
                ) }}
            </div>

        </div>
    </div>
</div>
{% endblock %}
