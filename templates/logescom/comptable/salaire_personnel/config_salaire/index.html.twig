{% extends 'base_comptable.html.twig' %}

{% block title %}Configuration des salaires{% endblock %}

{% block presentation %}
    <div class="row m-0 p-0">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}
        <div class="col-sm-12 col-md-10 m-0 p-0">
            {% include "_common/_messages_flash.html.twig" %}

        <h3 class="mb-4">
            <i class="fa fa-gears me-2 text-primary"></i>
            Configuration des salaires
        </h3>

        <div class="card shadow-sm border-0">

            <!-- 🔹 Header -->
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <span>
                    <i class="fa fa-list me-1"></i> Paramètres disponibles
                </span>
                
                <a href="{{ path('app_logescom_comptable_salaire_personnel_config_salaire_new', {site : site.id}) }}"
                class="btn btn-success btn-sm">
                    <i class="fa fa-plus-circle me-1"></i>
                    Nouvelle configuration
                </a>
            </div>

            <!-- 📊 Table -->
            <div class="card-body bg-light">

                {% if config_salaires is not empty %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle text-center">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Code</th>
                                    <th>Libellé</th>
                                    <th>Taux (%)</th>
                                    <th>Type</th>
                                    <th>Montant</th>
                                    <th>Statut</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                            {% for config in config_salaires %}
                                <tr>
                                    <td>{{ loop.index }}</td>

                                    <td class="fw-bold text-primary">
                                        {{ config.code }}
                                    </td>

                                    <td class="text-start">
                                        {{ config.libelle }}
                                    </td>

                                    <td>
                                        {{ config.taux is not null ? config.taux ~ ' %' : '—' }}
                                    </td>

                                    <td>
                                        <span class="badge bg-info">
                                            {{ config.type|capitalize }}
                                        </span>
                                    </td>

                                    <td>
                                        {{config.montant|number_format(0,',',' ')}}
                                    </td>

                                    <td>
                                        {% if config.actif %}
                                            <span class="badge bg-success">Actif</span>
                                        {% else %}
                                            <span class="badge bg-danger">Inactif</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path(
                                                'app_logescom_comptable_salaire_personnel_config_salaire_show',
                                                { id: config.id, site : site.id }
                                            ) }}"
                                            class="btn btn-outline-success"
                                            title="Voir">
                                                <i class="fa fa-eye"></i>
                                            </a>

                                            <a href="{{ path(
                                                'app_logescom_comptable_salaire_personnel_config_salaire_edit',
                                                { id: config.id, site : site.id }
                                            ) }}"
                                            class="btn btn-outline-warning"
                                            title="Modifier">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="alert alert-secondary text-center mb-0">
                        <i class="fa fa-info-circle me-1"></i>
                        Aucune configuration de salaire enregistrée.
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
</div>
{% endblock %}
