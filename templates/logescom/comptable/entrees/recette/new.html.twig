{% extends 'base_comptable.html.twig' %}

{% block title %}💸 Nouvelle recette{% endblock %}

{% block presentation %}
<div class="container-fluid px-3">
    <div class="row">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}
        <div class="col-sm-12 col-md-10">
            {{ include("_common/_messages_flash.html.twig") }}

            <div class="card shadow-lg border-0 mb-4 rounded-3">
                <!-- 🔹 En-tête -->
                <div class="card-header bg-dark text-white py-3 px-4">
                    <h5 class="mb-0">
                        <i class="fa fa-coins me-2 text-warning"></i>
                        Enregistrer une nouvelle recette
                    </h5>
                </div>

                <!-- 📋 Formulaire -->
                <div class="card-body bg-light p-4">
                    <p class="text-muted mb-4">
                        Veuillez remplir les champs ci-dessous pour enregistrer une recette.
                    </p>

                    {{ include('logescom/comptable/entrees/recette/_form.html.twig', {'button_label': 'Valider'}) }}

                    <div class="mt-4 d-flex justify-content-between">
                        <a class="btn btn-outline-secondary rounded-pill"
                           href="{{ path('app_logescom_comptable_entrees_recette_index', { site: site.id }) }}">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header h5 i {
        color: #ffc107;
    }
</style>
{% endblock %}
