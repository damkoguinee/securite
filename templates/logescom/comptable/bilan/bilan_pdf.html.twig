<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Bilan de la site {{ site.nom }}</title>

    <style>
        @page { margin: 20px 25px; }
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 11px;
            color: #222;
        }

        h3, h4 { margin: 6px 0; }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
            page-break-inside: avoid;
        }

        th, td {
            border: 1px solid #999;
            padding: 5px;
            vertical-align: middle;
        }

        th {
            background-color: #e0f2f7;
            font-weight: bold;
            text-align: center;
        }

        td {
            text-align: right;
        }

        td:first-child, th:first-child {
            text-align: left;
        }

        .header {
            text-align: center;
            border-bottom: 2px solid #444;
            margin-bottom: 15px;
            padding-bottom: 10px;
        }

        .header img {
            height: 60px;
            margin-bottom: 5px;
        }

        .section-title {
            background-color: #bde0fe;
            font-weight: bold;
            padding: 4px;
            margin-top: 10px;
        }

        .fw-bold { font-weight: bold; }
        .text-center { text-align: center; }
        .text-end { text-align: right; }
        .text-success { color: #198754; }
        .text-danger { color: #dc3545; }
        .text-info { color: #0dcaf0; }
        .table-info th { background-color: #bde0fe; }
    </style>
</head>
<body>

<div class="header">
    {% if logoPath is defined %}
        <img src="data:image/png;base64,{{ logoPath }}" alt="Logo">
    {% endif %}
    <h3>{{ site.entreprise.nom|upper }} - {{ site.nom|upper }}</h3>
    <h4>Bilan du {{ date1|date('d/m/Y') }} au {{ date2|date('d/m/Y') }}</h4>
</div>

<h4 class="section-title">Situation des caisses</h4>
<table>
    <thead>
        <tr>
            <th>Désignation</th>
            {% for devise in devises %}
                <th>{{ devise.nom|upper }}</th>
            {% endfor %}
        </tr>
    </thead>
    <tbody>
        {% for caisse, solde_caisse in solde_caisses %}
            <tr>
                <td class="fw-bold">{{ caisse|capitalize }}</td>
                {% for solde in solde_caisse %}
                    <td>
                        {{ solde.nomDevise == 'gnf'
                            ? solde.solde|number_format(0,',',' ')
                            : solde.solde|number_format(2,',',' ') }}
                    </td>
                {% endfor %}
            </tr>
        {% else %}
            <tr>
                <td colspan="{{ devises|length + 1 }}" class="text-center">
                    Aucune donnée disponible.
                </td>
            </tr>
        {% endfor %}
    </tbody>
    <tfoot>
        <tr class="fw-bold">
            <td>Totaux</td>
            {% for cumul in solde_caisses_devises %}
                <td>
                    {{ cumul.nomDevise == 'gnf'
                        ? cumul.solde|number_format(0,',',' ')
                        : cumul.solde|number_format(2,',',' ') }}
                </td>
            {% endfor %}
        </tr>
    </tfoot>
</table>

{# <h4 class="section-title">Bilan Journalier</h4>
