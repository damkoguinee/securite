{% extends 'base_comptable.html.twig' %}
{% block title %}💸 Liste des transferts de fonds{% endblock %}

{% block presentation %}
<div class="container-fluid px-3">
    {% include "_common/_messages_flash.html.twig" %}

    <div class="row">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

        <div class="col-sm-12 col-md-10">
            <div class="card shadow-lg border-0 mb-4">

                <!-- 🔹 En-tête -->
                <div class="card-header bg-info text-white py-3 px-4 d-flex flex-wrap justify-content-between align-items-center">
                    <h5 class="mb-3 mb-md-0">
                        <i class="fa fa-random me-2"></i> Liste des transferts de fonds
                    </h5>

                    <!-- 🔍 Filtres -->
                    <div class="filters d-flex flex-wrap align-items-center gap-2">
                        <form class="d-flex flex-wrap align-items-center gap-2">
                            <div class="d-flex align-items-center gap-1">
                                <label class="fw-semibold text-white mb-0">Du</label>
                                <input type="date" name="date1" value="{{ date1 }}"
                                       class="form-control form-control-sm shadow-sm border-0 rounded-pill"
                                       onchange="this.form.submit()">
                            </div>

                            <div class="d-flex align-items-center gap-1">
                                <label class="fw-semibold text-white mb-0">au</label>
                                <input type="date" name="date2" value="{{ date2 }}"
                                       class="form-control form-control-sm shadow-sm border-0 rounded-pill"
                                       onchange="this.form.submit()">
                            </div>

                            <select name="caisse" class="form-select form-select-sm shadow-sm rounded-pill"
                                    onchange="this.form.submit()">
                                <option value="{{ search ? search.id : '' }}">
                                    {{ search ? search.nom|ucfirst : 'Filtrer par caisse' }}
                                </option>
                                {% for caisse in caisses %}
                                    <option value="{{ caisse.id }}">{{ caisse.nom|ucfirst }}</option>
                                {% endfor %}
                            </select>
                        </form>

                        <!-- ➕ Nouveau transfert -->
                        <a href="{{ path('app_logescom_comptable_caisse_transfert_fond_new', {site: site.id}) }}"
                           class="btn btn-sm btn-warning rounded-pill shadow-sm">
                            <i class="fa fa-plus-circle me-1"></i> Nouveau
                        </a>
                    </div>
                </div>

                <!-- 📋 Corps principal -->
                <div class="card-body bg-light p-4">
                    {% if transfert_fonds.data is not empty %}
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered align-middle shadow-sm">
                                <thead class="table-dark text-center align-middle">
                                    <tr>
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Référence</th>
                                        <th>Montant</th>
                                        <th>Devise</th>
                                        <th>Caisse Départ</th>
                                        <th>Caisse Réception</th>
                                        <th>Commentaire</th>
                                        <th>Saisie Par</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>

                                <tbody class="bg-white text-center">
                                    {% for key, transfert in transfert_fonds.data %}
                                        <tr>
                                            <td class="fw-semibold">
                                                {{ key + 1 }}
                                                {% if transfert.document %}
                                                    <a href="{{ asset('caisse/' ~ transfert.document) }}" target="_blank">
                                                        <i class="fa fa-file-pdf text-danger ms-1"></i>
                                                    </a>
                                                {% endif %}
                                            </td>
                                            <td>{{ transfert.dateOperation ? transfert.dateOperation|date('d/m/Y') : '—' }}</td>
                                            <td class="text-uppercase">{{ transfert.reference }}</td>
                                            <td class="text-end fw-bold">
                                                {% if transfert.devise.nom == 'gnf' %}
                                                    {{ transfert.montant|abs|number_format(0, '.', ' ') }}
                                                {% else %}
                                                    {{ transfert.montant|abs|number_format(2, ',', ' ') }}
                                                {% endif %}
                                            </td>
                                            <td>{{ transfert.devise.nom|upper }}</td>
                                            <td>{{ transfert.caisse ? transfert.caisse.nom|capitalize : '—' }}</td>
                                            <td>{{ transfert.caisseReception ? transfert.caisseReception.nom|capitalize : '—' }}</td>
                                            <td>{{ transfert.commentaire|capitalize }}</td>
                                            <td>{{ transfert.saisiePar.prenom|ucwords }} {{ transfert.saisiePar.nom|upper }}</td>
                                            <td>
                                                <a href="{{ path('app_logescom_comptable_caisse_transfert_fond_show', {'id': transfert.id, 'site': site.id}) }}"
                                                   class="btn btn-sm btn-outline-success"
                                                   title="Voir le détail">
                                                    <i class="fa fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="alert alert-secondary text-center my-4">
                            <i class="fa fa-info-circle me-1"></i> Aucun transfert trouvé pour cette période.
                        </div>
                    {% endif %}

                    <!-- 📄 Pagination -->
                    {% if transfert_fonds.nbrePages > 1 %}
                        <nav class="mt-3">
                            <ul class="pagination justify-content-center">
                                <!-- ⬅️ Précédent -->
                                <li class="page-item {{ transfert_fonds.pageEnCours == 1 ? 'disabled' : '' }}">
                                    <a class="page-link"
                                       href="{{ path(app.request.attributes.get('_route'),
                                           app.request.query.all | merge({'pageEnCours': transfert_fonds.pageEnCours - 1, 'site': site.id})) }}">
                                       &laquo;
                                    </a>
                                </li>

                                {% set start = max(1, transfert_fonds.pageEnCours - 2) %}
                                {% set end = min(transfert_fonds.nbrePages, transfert_fonds.pageEnCours + 2) %}

                                {% if start > 1 %}
                                    <li class="page-item"><a class="page-link"
                                        href="{{ path(app.request.attributes.get('_route'),
                                        app.request.query.all | merge({'pageEnCours': 1, 'site': site.id})) }}">1</a></li>
                                    {% if start > 2 %}
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    {% endif %}
                                {% endif %}

                                {% for i in start..end %}
                                    <li class="page-item {{ i == transfert_fonds.pageEnCours ? 'active' : '' }}">
                                        <a class="page-link"
                                           href="{{ path(app.request.attributes.get('_route'),
                                           app.request.query.all | merge({'pageEnCours': i, 'site': site.id})) }}">{{ i }}</a>
                                    </li>
                                {% endfor %}

                                {% if end < transfert_fonds.nbrePages %}
                                    {% if end < transfert_fonds.nbrePages - 1 %}
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    {% endif %}
                                    <li class="page-item">
                                        <a class="page-link"
                                           href="{{ path(app.request.attributes.get('_route'),
                                           app.request.query.all | merge({'pageEnCours': transfert_fonds.nbrePages, 'site': site.id})) }}">
                                           {{ transfert_fonds.nbrePages }}
                                        </a>
                                    </li>
                                {% endif %}

                                <!-- ➡️ Suivant -->
                                <li class="page-item {{ transfert_fonds.pageEnCours == transfert_fonds.nbrePages ? 'disabled' : '' }}">
                                    <a class="page-link"
                                       href="{{ path(app.request.attributes.get('_route'),
                                           app.request.query.all | merge({'pageEnCours': transfert_fonds.pageEnCours + 1, 'site': site.id})) }}">
                                       &raquo;
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #result-search {
        max-height: 250px;
        overflow-y: auto;
    }
    #result-search .list-group-item:hover {
        background-color: #f8f9fa;
    }
</style>
{% endblock %}
