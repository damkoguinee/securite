{% extends 'base_comptable.html.twig' %}

{% block title %}💸 Détail du transfert de fonds{% endblock %}

{% block presentation %}
<div class="container-fluid px-3">
    <div class="row">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

        <div class="col-sm-12 col-md-10">
            {% include "_common/_messages_flash.html.twig" %}

            <div class="card shadow-lg border-0 mb-4">
                <!-- 🔹 En-tête -->
                <div class="card-header bg-dark text-white text-center py-3">
                    <h5 class="mb-0">
                        <i class="fa fa-random me-2 text-warning"></i> Détail du transfert de fonds
                    </h5>
                </div>

                <!-- 📋 Détails -->
                <div class="card-body bg-light p-4">
                    <table class="table table-bordered table-striped align-middle bg-white shadow-sm">
                        <tbody>
                            <tr>
                                <th style="width: 30%;">💬 Description</th>
                                <td>{{ transfert_fond.commentaire|default('—') }}</td>
                            </tr>
                            <tr>
                                <th>💰 Montant transféré</th>
                                <td>
                                    <strong>
                                        {{ transfert_fond.devise.nom == 'gnf'
                                            ? transfert_fond.montant|abs|number_format(0,',',' ')
                                            : transfert_fond.montant|abs|number_format(2,',',' ') }}
                                        {{ transfert_fond.devise.nom|upper }}
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <th>💱 Devise</th>
                                <td>{{ transfert_fond.devise.nom|upper }}</td>
                            </tr>
                            <tr>
                                <th>🏦 Compte de départ</th>
                                <td>{{ transfert_fond.caisse ? transfert_fond.caisse.nom|capitalize : '—' }}</td>
                            </tr>
                            <tr>
                                <th>🏦 Compte de réception</th>
                                <td>{{ transfert_fond.caisseReception ? transfert_fond.caisseReception.nom|capitalize : '—' }}</td>
                            </tr>
                            <tr>
                                <th><i class="fas fa-file-pdf text-danger me-1"></i> Document</th>
                                <td>
                                    {% if transfert_fond.document %}
                                        <a href="{{ asset(chemin_caisses ~ transfert_fond.document) }}"
                                           target="_blank"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-file-pdf me-1"></i> Voir le document
                                        </a>
                                    {% else %}
                                        <span class="text-muted fst-italic">Aucun document joint</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>📅 Date de l’opération</th>
                                <td>{{ transfert_fond.dateOperation ? transfert_fond.dateOperation|date('d/m/Y H:i') : '—' }}</td>
                            </tr>
                            <tr>
                                <th>🕒 Date de saisie</th>
                                <td>{{ transfert_fond.dateSaisie ? transfert_fond.dateSaisie|date('d/m/Y H:i') : '—' }}</td>
                            </tr>
                            <tr>
                                <th>👤 Traité par</th>
                                <td>
                                    {{ transfert_fond.saisiePar.prenom|ucwords }}
                                    {{ transfert_fond.saisiePar.nom|upper }}
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- 🔘 Actions -->
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a href="{{ path('app_logescom_comptable_caisse_transfert_fond_index', {'site': site.id}) }}"
                           class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_logescom_comptable_caisse_transfert_fond_edit', {'id': transfert_fond.id, 'site': site.id}) }}"
                               class="btn btn-outline-warning">
                                <i class="fa fa-edit me-1"></i> Modifier
                            </a>

                            {% if is_granted('ROLE_SUPPRESSION') %}
                                <form method="post"
                                      action="{{ path('app_logescom_comptable_caisse_transfert_fond_confirm_delete', {'id': transfert_fond.id}) }}"
                                      onsubmit="return confirm('Voulez-vous vraiment annuler ce transfert ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ transfert_fond.id) }}">
                                    <input type="hidden" name="param" value="simple">
                                    <button class="btn btn-outline-danger">
                                        <i class="fa fa-times-circle me-1"></i> Annuler
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    table th {
        background-color: #f8f9fa;
        width: 35%;
    }

    table td {
        background-color: #fff;
    }

    .card-header h5 {
        letter-spacing: 0.5px;
    }
</style>
{% endblock %}
