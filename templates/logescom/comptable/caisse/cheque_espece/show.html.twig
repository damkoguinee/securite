{% extends 'base_comptable.html.twig' %}

{% block title %}Détail transfert fond{% endblock %}

{% block presentation %}
    <div class="row m-0 p-0">
        {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}

        <div class="col-sm-12 col-md-10 m-0 p-0 m-auto">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0 text-center">Détail transfert fond</h5>
                </div>
                <div class="card-body">
                    <table class="table table-bordered table-striped table-hover align-middle">
                        <tbody>
                            <tr>
                                <th>Collaborateur</th>
                                <td>{{ cheque_espece.collaborateur.prenom|ucwords ~ " " ~ cheque_espece.collaborateur.nom |strtoupper }}</td>
                            </tr>
                            <tr>
                                <th>Commentaire</th>
                                <td>{{ cheque_espece.commentaire|ucfirst }}</td>
                            </tr>

                            <tr>
                                <th>Montant du Chèque</th>
                                <td>{{ cheque_espece.montantCheque|number_format(0,',',' ') }}</td>
                            </tr>
                            <tr>
                                <th>Numéro du Chèque</th>
                                <td>{{ cheque_espece.numeroCheque }}</td>
                            </tr>
                            <tr>
                                <th>Banque Chèque</th>
                                <td>{{ cheque_espece.banqueCheque }}</td>
                            </tr>
                            <tr>
                                <th>Caisse de Dépôt</th>
                                <td>{{ cheque_espece.caisseDepot.nom|capitalize }}</td>

                            </tr>

                            <tr>
                                <th>Montant du Réçu</th>
                                <td>{{ cheque_espece.montantRecu|number_format(0,',',' ') }}</td>
                            </tr>
                            <tr>
                                <th>Caisse de Retraît</th>
                                <td>{{ cheque_espece.caisseRetrait.nom|capitalize }}</td>

                            </tr>

                            <tr>
                                <th>Date Opération</th>
                                <td>{{ cheque_espece.dateOperation ? cheque_espece.dateOperation|date('d/m/Y') : '' }}</td>
                            </tr>
                            <tr>
                                <th>Date de Saisie</th>
                                <td>{{ cheque_espece.dateSaisie ? cheque_espece.dateSaisie|date('d/m/Y H:i:s') : '' }}</td>
                            </tr>
                            <tr>
                                <th>Traité par</th>
                                <td>{{ cheque_espece.saisiePar.prenom|ucwords ~ " " ~ cheque_espece.saisiePar.nom |strtoupper }}</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between my-4">
                        <a class="btn btn-outline-primary" href="{{ path('app_logescom_comptable_caisse_cheque_espece_index', {'site': site.id}) }}">
                            <i class="fa fa-arrow-left"></i> Retour à la liste
                        </a>

                        
                        <a class="btn btn-outline-warning" href="{{ path('app_logescom_comptable_caisse_cheque_espece_edit', {'id': cheque_espece.id, 'site' : site.id}) }}">
                            <i class="fa fa-edit"></i> Modifier
                        </a>


                        {% if is_granted("ROLE_SUPPRESSION") %}
                            {{ include('logescom/comptable/caisse/cheque_espece/_delete_form.html.twig') }}
                        {% endif %}

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
