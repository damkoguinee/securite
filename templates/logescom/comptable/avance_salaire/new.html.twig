{% extends 'base_comptable.html.twig' %}

{% block title %}Nouvelle avance sur salaire{% endblock %}

{% block presentation %}
<div class="row m-0 p-0">
    {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}
     <div class="col-sm-12 col-md-10 m-0 p-0">
        {% include "_common/_messages_flash.html.twig" %}

        <div class="card shadow-lg border-0 rounded-3 mb-4">
            <!-- 🔹 En-tête -->
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fa fa-hand-holding-usd me-2"></i> Enregistrer une avance sur salaire
                </h5>
                <a href="{{ path('app_logescom_comptable_avance_salaire_index', { site: site.id }) }}"
                class="btn btn-outline-light btn-sm">
                    <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                </a>
            </div>

            <!-- 🧾 Formulaire -->
            <div class="card-body bg-light">
                {{ include('logescom/comptable/avance_salaire/_form.html.twig', { button_label: 'Valider' }) }}
            </div>
        </div>
    </div>
</div>

{% endblock %}
