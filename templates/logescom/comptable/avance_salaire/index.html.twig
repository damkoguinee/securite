{% extends 'base_comptable.html.twig' %}

{% block title %}Liste des avances sur salaire{% endblock %}

{% block presentation %}
<div class="row m-0 p-0">
    {% include "logescom/comptable/caisse/_nav_caisse.html.twig" %}
     <div class="col-sm-12 col-md-10 m-0 p-0">
        {% include "_common/_messages_flash.html.twig" %}

        <!-- 🧾 Carte principale -->
        <div class="card shadow-sm border-0 mb-4">

            <!-- 🔹 En-tête -->
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fa fa-hand-holding-usd me-2"></i> Liste des avances sur salaire
                </h5>
                <a class="btn btn-primary btn-sm"
                href="{{ path('app_logescom_comptable_avance_salaire_new', { site: site.id }) }}">
                    <i class="fa fa-plus-circle me-1"></i> Nouvelle avance
                </a>
            </div>

            <!-- 📊 Contenu -->
            <div class="card-body bg-light">
                {% set cumulGeneral = 0 %}

                {% if avancesParMois is not empty %}
                    {% for mois, avances in avancesParMois %}
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-header bg-secondary bg-opacity-75 text-white d-flex justify-content-between align-items-center">
                                <h6 class="mb-0 text-uppercase">
                                    <i class="fa fa-calendar-alt me-1"></i> Mois : {{ mois }}
                                </h6>
                            </div>

                            <div class="card-body p-2">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle text-center">
                                        <thead class="table-dark">
                                            <tr>
                                                <th>#</th>
                                                <th>Date</th>
                                                <th>Bénéficiaire</th>
                                                <th>Montant</th>
                                                <th>Type de paie</th>
                                                <th>Caisse</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% set cumulMois = 0 %}
                                            {% for key, avance in avances %}
                                                {% set cumulMois = cumulMois + avance.montant %}
                                                {% set cumulGeneral = cumulGeneral + avance.montant %}
                                                <tr>
                                                    <td>{{ key + 1 }}</td>
                                                    <td>{{ avance.dateOperation ? avance.dateOperation|date('d/m/Y') : '—' }}</td>
                                                    <td class="text-start">
                                                        <i class="fa fa-user text-primary me-1"></i>
                                                        {{ avance.personnel.prenom|capitalize }} {{ avance.personnel.nom|upper }}
                                                    </td>
                                                    <td class="text-end fw-semibold">{{ avance.montant|abs|number_format(0, ',', ' ') }}</td>
                                                    <td>{{ avance.modePaie.designation|capitalize }}</td>
                                                    <td>{{ avance.caisse.nom|capitalize }}</td>
                                                    <td>
                                                        <a href="{{ path('app_logescom_comptable_avance_salaire_show', {'id': avance.id, site: site.id}) }}"
                                                        class="btn btn-sm btn-outline-success" title="Voir">
                                                            <i class="fa fa-eye"></i>
                                                        </a>
                                                        <a href="{{ path('app_logescom_comptable_avance_salaire_edit', {'id': avance.id, site: site.id}) }}"
                                                        class="btn btn-sm btn-outline-warning" title="Modifier">
                                                            <i class="fa fa-edit"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                        <tfoot class="table-secondary fw-bold">
                                            <tr>
                                                <td colspan="3" class="text-end">Total {{ mois }}</td>
                                                <td class="text-end">{{ cumulMois|abs|number_format(0, ',', ' ') }}</td>
                                                <td colspan="3"></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    {% endfor %}

                    <!-- 🔹 Total général -->
                    <div class="alert alert-info fw-bold text-end mt-4 mb-0 shadow-sm">
                        <i class="fa fa-coins me-1"></i> Total général :
                        <span class="text-dark">{{ cumulGeneral|abs|number_format(0, ',', ' ') }} GNF</span>
                    </div>

                {% else %}
                    <div class="alert alert-secondary text-center my-4">
                        <i class="fa fa-info-circle me-1"></i> Aucune avance sur salaire enregistrée.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
