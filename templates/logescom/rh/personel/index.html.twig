{% extends 'base_rh.html.twig' %}

{% block title %}Liste du personnel{% endblock %}

{% block presentation %}
<div class="row m-0 p-0">
    {# {% include "logescom/rh/_nav_rh.html.twig" %} #}
    
    <div class="col-sm-12 col-md-12 m-auto p-0">
        {% include "_common/_messages_flash.html.twig" %}

        <div class="container-fluid py-3">
            
            <!-- 🏷️ En-tête -->
            <div class="d-flex justify-content-between align-items-center bg-dark text-white rounded-3 p-3 shadow-sm mb-3">
                <h4 class="m-0">
                    <i class="fa fa-users me-2"></i> Gestion du personnel
                </h4>
                <!-- 👤 Recherche agent -->
                <div class="position-relative" style="min-width: 280px;">
                    <input type="text" name="search" id="search_client"
                           class="form-control form-control-sm shadow-sm rounded-pill ps-4 "
                           placeholder="🔍 Rechercher un agent (Nom, téléphone...)">
                    <div id="result-search" class="bg-white" style="z-index: 1000;"></div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <form class="d-flex align-items-center gap-2" style="flex-wrap: wrap;">
                        {% set zoneSelected = app.request.get('zone') %}

                        <select name="zone" id="zone" class="form-select" onchange="this.form.submit()">
                            <option value="">— Toutes les zones —</option>

                            {% for zone in zones %}
                                <option value="{{ zone.id }}"
                                    {{ zoneSelected is not null and zoneSelected == zone.id ? 'selected' : '' }}>
                                    {{ zone.nom|upper }}
                                </option>
                            {% endfor %}
                        </select>
                    </form>
                </div>
                <a class="btn btn-outline-light btn-sm" href="{{ path('app_logescom_rh_personel_new', {site : site.id}) }}">
                    <i class="fa fa-plus-circle me-1"></i> Nouveau personnel
                </a>
            </div>

            <!-- 🧾 Tableau -->
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body bg-light">
                    {% if personnelsGroupes is empty %}
                        <div class="alert alert-warning text-center mb-0">
                            <i class="fa fa-info-circle me-1"></i>
                            Aucun personnel n’a encore été enregistré.
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered align-middle shadow-sm mb-0">
                                <thead class="table-dark text-center align-middle">
                                    <tr>
                                        <th>#</th>
                                        <th>Nom complet</th>
                                        <th>Téléphone</th>
                                        <th>Email</th>
                                        <th>Fonction</th>
                                        <th>Affectation</th>
                                        <th class="text-end">Taux Horaire</th>
                                        <th class="text-end">Salaire de Base</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                {% set globalIndex = 1 %}

                                {% for groupe in personnelsGroupes %}

                                    {# 🔹 Ligne titre ZONE #}
                                    <tr class="table-secondary">
                                        <td colspan="9" class="fw-bold text-uppercase">
                                            <i class="fa fa-map-marker-alt me-2 text-primary"></i>
                                            {{ groupe.zone_nom }}
                                            <span class="badge bg-primary ms-2">
                                                {{ groupe.personnels|length }}
                                            </span>

                                            
                                        </td>
                                    </tr>

                                    {# 🔹 Lignes personnels #}
                                    {% for personel in groupe.personnels %}
                                        <tr>
                                            <td class="text-center fw-bold">{{ globalIndex }}</td>

                                            <td>
                                                <div class="fw-semibold text-dark">
                                                    {{ personel.nom|upper }} {{ personel.prenom|capitalize }}
                                                </div>
                                                <small class="text-muted fst-italic">
                                                    @{{ personel.reference|upper }}
                                                </small>
                                            </td>

                                            <td class="text-center">
                                                {{ personel.telephone ?: '-' }}
                                            </td>

                                            <td>
                                                {{ personel.email ?: '<em class="text-muted">Non défini</em>'|raw }}
                                            </td>

                                            <td>
                                                {{ personel.fonction ?: '<em class="text-muted">Non précisée</em>'|raw }}
                                            </td>

                                            <td>
                                                {% if personel.bienAffecte is not empty %}
                                                    {{ personel.bienAffecte.nom ?? '' }}
                                                {% endif %}
                                            </td>

                                            <td class="text-end fw-semibold text-success">
                                                {{ personel.tauxHoraire
                                                    ? personel.tauxHoraire|number_format(0, ',', ' ')
                                                    : '-' }}
                                            </td>

                                            <td class="text-end fw-semibold text-primary">
                                                {{ personel.salaireBase
                                                    ? personel.salaireBase|number_format(0, ',', ' ')
                                                    : '-' }}
                                            </td>

                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm">
                                                    <a class="btn btn-outline-success mx-1"
                                                    href="{{ path('app_logescom_rh_personel_show', {'id': personel.id, site: site.id}) }}"
                                                    title="Voir les détails">
                                                        <i class="fa fa-eye"></i>
                                                    </a>
                                                    <a class="btn btn-outline-warning"
                                                    href="{{ path('app_logescom_rh_personel_edit', {'id': personel.id, site: site.id}) }}"
                                                    title="Modifier">
                                                        <i class="fa fa-edit"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>

                                        {% set globalIndex = globalIndex + 1 %}
                                    {% endfor %}

                                {% else %}
                                    <tr>
                                        <td colspan="9" class="text-center text-muted fst-italic">
                                            Aucun personnel trouvé
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>

                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
