{% extends 'base_rh.html.twig' %}

{% block title %}Modifier le personnel – {{ personel.nomCompletUser }}{% endblock %}

{% block presentation %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-md-12">

            <!-- 🏷️ En-tête -->
            <div class="text-center mb-3">
                <h4 class="fw-bold text-dark">
                    <i class="fa fa-user-edit me-2 text-warning"></i> Modifier le personnel
                </h4>
                <p class="text-muted mb-0">
                    Mettez à jour les informations de <strong>{{ personel.nomCompletUser|capitalize }}</strong>.
                </p>
            </div>

            <!-- 🧾 Carte principale -->
            <div class="card border-0 shadow-lg rounded-3">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-2">
                    <h6 class="mb-0">
                        <i class="fa fa-id-badge me-1"></i> Personnel : {{ personel.reference|default('—') }}
                    </h6>
                    {% if personel.photo %}
                        <img src="{{ asset(chemin_images_personnels ~ personel.photo) }}" 
                             alt="Photo de {{ personel.nomCompletUser }}" 
                             class="rounded-circle border border-light"
                             style="height: 60px; width: 60px; object-fit: cover;">
                    {% endif %}
                </div>

                <div class="card-body bg-light">
                    <!-- 🧍‍♂️ Formulaire -->
                    {{ include('logescom/rh/personel/_form.html.twig', { 'button_label': 'Modifier' }) }}

                    <hr class="my-3">

                    <!-- 🔙 Boutons -->
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_logescom_rh_personel_index', { site: site.id }) }}" 
                           class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>

                        <div class="d-flex gap-2">
                            {% if is_granted('ROLE_SUPPRESSION') %}
                                {{ include('logescom/rh/personel/_delete_form.html.twig') }}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
