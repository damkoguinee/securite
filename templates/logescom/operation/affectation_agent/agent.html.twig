{% extends 'base_operation.html.twig' %}

{% block title %}Liste du personnel{% endblock %}

{% block presentation %}
<div class="row m-0 p-0">
    {# {% include "logescom/rh/_nav_rh.html.twig" %} #}
    
    <div class="col-sm-12 col-md-12 m-auto p-0">
        {% include "_common/_messages_flash.html.twig" %}

        <div class="container-fluid py-3">
            
            <!-- 🏷️ En-tête -->
            <div class="d-flex justify-content-between align-items-center bg-dark text-white rounded-3 p-3 shadow-sm mb-3">
                <h4 class="m-0">
                    <i class="fa fa-users me-2"></i> Gestion du personnel
                </h4>
                <!-- 👤 Recherche agent -->
                <div class="position-relative" style="min-width: 280px;">
                    <input type="text" name="search" id="search_client"
                           class="form-control form-control-sm shadow-sm rounded-pill ps-4 "
                           placeholder="🔍 Rechercher un agent (Nom, téléphone...)">
                    <div id="result-search" class="bg-white" style="z-index: 1000;"></div>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <form class="d-flex align-items-center gap-2" style="flex-wrap: wrap;">
                        {% set personnelSelected = app.request.get('id_client_search') %}
                        <input type="hidden" name="id_client_search" value="{{ personnelSelected }}">
                        {% set zoneSelected = app.request.get('zone') %}

                        <select name="zone" id="zone" class="form-select" onchange="this.form.submit()">
                            <option value="">— Toutes les zones —</option>

                            {% for zone in zones %}
                                <option value="{{ zone.id }}"
                                    {{ zoneSelected is not null and zoneSelected == zone.id ? 'selected' : '' }}>
                                    {{ zone.nom|upper }}
                                </option>
                            {% endfor %}
                        </select>
                    </form>
                </div>
                <a class="btn btn-outline-light btn-sm" href="{{ path('app_logescom_rh_personel_new', {site : site.id}) }}">
                    <i class="fa fa-plus-circle me-1"></i> Nouveau personnel
                </a>
            </div>

            <!-- 🧾 Tableau -->
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body bg-light">
                    {% if personels is empty %}
                        <div class="alert alert-warning text-center mb-0">
                            <i class="fa fa-info-circle me-1"></i>
                            Aucun personnel n’a encore été enregistré.
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered align-middle shadow-sm mb-0">
                                <thead class="table-dark text-center align-middle">
                                    <tr>
                                        <th>#</th>
                                        <th>Réf</th>
                                        <th>Nom complet</th>
                                        <th>Téléphone</th>
                                        <th>Affectations</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for personel in personels %}
                                        <tr>
                                            <td class="text-center fw-bold">{{ loop.index }}</td>

                                            <td>{{ personel.reference|upper }}</td>

                                            <td>
                                                <div class="fw-semibold text-dark">
                                                    {{ personel.nomCompletUser }}
                                                </div>
                                                <small class="text-muted fst-italic">@{{ personel.username }}</small>
                                            </td>

                                            <td class="text-center">{{ personel.telephone ?: '-' }}</td>

                                            <td>
                                                <form
                                                    method="post"
                                                    action="{{ path('app_logescom_operation_affectation_agent_liste', {
                                                        site: site.id,
                                                        personel: personel.id
                                                    }) }}"
                                                    class="d-flex align-items-center gap-2"
                                                >
                                                    {# 🔐 CSRF #}
                                                    <input type="hidden" name="_token"
                                                        value="{{ csrf_token('affecter_agent_' ~ personel.id) }}">

                                                    {# 🔹 SELECT SIMPLE #}
                                                    <select
                                                        name="bien"
                                                        class="form-select"
                                                        style="min-width: 260px"
                                                    >
                                                        <option value="">— Sélectionner un bien —</option>

                                                        {% for bien in biens %}
                                                            <option
                                                                value="{{ bien.id }}"
                                                                {% if personel.bienAffecte is not null and personel.bienAffecte.id == bien.id %}
                                                                    selected
                                                                {% endif %}
                                                            >
                                                                {{ bien.client.nomComplet|capitalize }} - {{ bien.nom|capitalize }}
                                                            </option>
                                                        {% endfor %}
                                                    </select>


                                                    <input type="hidden" name="personel" value="{{ personel.id }}">

                                                    <button type="submit"
                                                            class="btn btn-sm btn-primary"
                                                            title="Affecter">
                                                        <i class="fa fa-check"></i>
                                                    </button>
                                                </form>
                                            </td>



                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm">
                                                    <a class="btn btn-sm btn-outline-primary me-1"
                                                    href="{{ path('app_logescom_operation_affectation_agent_liste_show', {'id': personel.id, site : site.id}) }}"
                                                    title="Voir les détails">
                                                        <i class="fa fa-eye"></i>
                                                    </a>

                                                    <a href="{{ path('app_logescom_operation_affectation_agent_planning', {site: site.id, personel : personel.id}) }}"
                                                    class="btn btn-sm btn-outline-success"
                                                    title="Planning">
                                                        <i class="fa fa-calendar"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>

                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
