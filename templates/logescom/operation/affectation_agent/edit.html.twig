{% extends 'base_operation.html.twig' %}

{% block title %}Modifier un créneau{% endblock %}

{% block presentation %}
<div class="row justify-content-center mt-3">
    <div class="col-12 col-md-11 col-lg-10">
        <div class="card border-0 shadow-sm rounded-3">
            <!-- 🟡 En-tête -->
            <div class="card-header bg-warning text-dark text-center rounded-top">
                <h4 class="mb-0">
                    <i class="fas fa-user-edit me-2"></i>Modifier un créneau
                </h4>
            </div>

            <!-- 📋 Corps -->
            <div class="card-body bg-light">

                {{ include('logescom/operation/affectation_agent/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

                <hr class="my-4">

                <div class="d-flex justify-content-between mt-4">
                    <a href="{{ path('app_logescom_operation_affectation_agent_index', {'site': site.id}) }}" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                    </a>

                    <div>
                        {{ include('logescom/operation/affectation_agent/_delete_form.html.twig') }}
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}
