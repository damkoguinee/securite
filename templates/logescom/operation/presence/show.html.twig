{% extends 'base.html.twig' %}

{% block title %}Presence{% endblock %}

{% block body %}
    <h1>Presence</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ presence.id }}</td>
            </tr>
            <tr>
                <th>DatePointage</th>
                <td>{{ presence.datePointage ? presence.datePointage|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>TypePointage</th>
                <td>{{ presence.typePointage }}</td>
            </tr>
            <tr>
                <th>Mode</th>
                <td>{{ presence.mode }}</td>
            </tr>
            <tr>
                <th>Latitude</th>
                <td>{{ presence.latitude }}</td>
            </tr>
            <tr>
                <th>Longitude</th>
                <td>{{ presence.longitude }}</td>
            </tr>
            <tr>
                <th>Commentaire</th>
                <td>{{ presence.commentaire }}</td>
            </tr>
            <tr>
                <th>DateSaisie</th>
                <td>{{ presence.dateSaisie ? presence.dateSaisie|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_logescom_operation_presence_index') }}">back to list</a>

    <a href="{{ path('app_logescom_operation_presence_edit', {'id': presence.id}) }}">edit</a>

    {{ include('logescom/operation/presence/_delete_form.html.twig') }}
{% endblock %}
