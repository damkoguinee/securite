<form method="post" action="{{ path('app_logescom_admin_entreprise_delete', {'id': entreprise.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entreprise.id) }}">
    <button class="btn btn-outline-danger"><i class="fa-solid fa-trash"></i> Supprimer</button>
</form>
