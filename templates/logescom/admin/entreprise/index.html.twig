{% extends 'base_admin.html.twig' %}

{% block title %}Liste des entreprises{% endblock %}

{% block presentation %}
    <div class="row m-0 p-0">
        {% include "logescom/admin/_nav_admin.html.twig" %}
        <div class="col-sm-12 col-md-10 m-0 p-0">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="m-0 text-center">Liste des entreprises</h5>
                </div>
                <div class="card-body">
                
                    <table class="table table-bordered table-striped table-hover align-middle">
                        <thead class="thead-dark table-dark">
                            {# <tr>
                                <th class="text-center" colspan="7">
                                    <h3 class="mb-0">Informations sur l'entreprise</h3>
                                </th>
                            </tr> #}
                            <tr>
                                <th class="text-center">ID</th>
                                <th class="text-center">Nom</th>
                                <th class="text-center">Identifiant</th>
                                <th class="text-center">Numéro d'agrément</th>
                                <th class="text-center">Téléphone</th>
                                <th class="text-center">Complément d'adresse</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-center">{{ entreprise.id }}</td>
                                <td>{{ entreprise.nom }}</td>
                                <td>{{ entreprise.identifiant }}</td>
                                <td>{{ entreprise.numeroAgrement }}</td>
                                <td>{{ entreprise.telephone }}</td>
                                <td>{{ entreprise.complementAdresse }}</td>
                                <td class="text-center">
                                    <a class="btn btn-success" href="{{ path('app_logescom_admin_entreprise_show', {'id': entreprise.id}) }}" aria-label="Voir l'entreprise"><i class="fa fa-eye"></i> Voir</a>
                                    <a class="btn btn-warning" href="{{ path('app_logescom_admin_entreprise_edit', {'id': entreprise.id}) }}" aria-label="Modifier l'entreprise"><i class="fa fa-edit"></i> Modifier</a>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    {# <div class="d-flex justify-content-between">
                        <a class="btn btn-primary" href="{{ path('app_logescom_admin_entreprise_new') }}" role="button">
                            <i class="fa fa-plus-circle"></i> Ajouter une nouvelle entreprise
                        </a>
                    </div> #}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
