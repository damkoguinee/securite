{{ form_start(form, { 'attr': { 'class': 'p-2' } }) }}
{{ form_errors(form) }}

<div class="row">

    <!-- NOM -->
    <div class="col-md-6 mb-3">
        {{ form_label(form.nom, 'Nom du type de bien *', {'label_attr': {'class': 'fw-semibold'}}) }}
        {{ form_widget(form.nom, {
            'attr': {
                'class': 'form-control shadow-sm',
            }
        }) }}
        {{ form_errors(form.nom) }}
    </div>

    

</div>

<!-- BOUTON -->
<div class="text-center mt-4">
    <button class="btn btn-primary px-4">
        <i class="fa fa-save me-1"></i> {{ button_label|default('Enregistrer') }}
    </button>
</div>

{{ form_end(form) }}
