{% extends 'base_admin.html.twig' %}

{% block title %}Détails de la Caisse{% endblock %}

{% block presentation %}
    <div class="row m-0 p-0">
        {% include "logescom/admin/_nav_admin.html.twig" %}  
        <div class="col-sm-12 col-md-10 m-0 p-0">
            <div class="card shadow-sm mb-4">
                    <!-- Titre et section de détails -->
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0 text-center">Détail de la caisse</h5>
                </div>
                <div class="card-body">
                    <table  class="table table-bordered table-striped table-hover align-middle">
                        <tbody>
                            <tr>
                                <th>Id</th>
                                <td>{{ caisse.id }}</td> 
                            </tr>
                            <tr>
                                <th>Nom</th>
                                <td>{{ caisse.nom }}</td>
                            </tr>
                            <tr>
                                <th>Type</th>
                                <td>{{ caisse.type }}</td>
                            </tr>
                            <tr>
                                <th>Numero</th>
                                <td>{{ caisse.numero }}</td>
                            </tr>

                            <tr>
                                <th>Sites liés</th>
                                <td>
                                    {% if caisse.site is not empty %}
                                        <ul>
                                            {% for site in caisse.site %}
                                                <li>{{ site.nom }}</li>
                                            {% endfor %}
                                        </ul>
                                    {% else %}
                                        <em>Aucun site lié</em>
                                    {% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between my-4">
                        <a class="btn btn-outline-primary" href="{{ path('app_logescom_admin_caisse_index') }}"><i class="fa fa-arrow-left"></i> Retour</a>

                        <a class="btn btn-outline-warning" href="{{ path('app_logescom_admin_caisse_edit', {'id': caisse.id}) }}"><i class="fa fa-edit"></i> Modifier</a>

                        {{ include('logescom/admin/caisse/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>   
        </div>
    </div>
{% endblock %}
