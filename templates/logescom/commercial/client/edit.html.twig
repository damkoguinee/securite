{% extends 'base_site.html.twig' %}

{% set queryParams = app.request.query.all %}
{% set queryString = queryParams|filter((v, k) => k not in ['page', 'ajustement', 'id_stock']) | url_encode %}

{% block title %}Modifier le client – {{ client.reference|upper }}{% endblock %}

{% block presentation %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-10">

            <!-- 🏷️ En-tête -->
            <div class="text-center mb-1">
                <p class="text-muted fs-6">
                    Modifiez les informations du client avec attention avant d’enregistrer les changements.
                </p>
            </div>

            <!-- 🧾 Carte principale -->
            <div class="card border-0 shadow-lg rounded-3">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center p-3">
                    <h5 class="mb-0">
                        <i class="fa fa-user-edit me-2"></i> Modifier le client : 
                        <span class="fw-bold">{{ client.reference|upper }}</span>
                    </h5>
                    {% if client.photo %}
                        <img src="{{ asset(chemin_images_clients ~ client.photo) }}" 
                             alt="Photo du client" 
                             class="rounded-circle shadow-sm" 
                             style="height: 60px; width: 60px; object-fit: cover;">
                    {% endif %}
                </div>

                <div class="card-body p-2 bg-light">
                    <!-- 🧍‍♂️ Formulaire -->
                    {{ include('logescom/commercial/client/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

                    <hr class="my-2">

                    <!-- 🔙 Boutons de navigation -->
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_logescom_commercial_client_index', {'site': site.id}) }}" 
                           class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>

                        <div class="d-flex gap-2">
                            {% if is_granted('ROLE_SUPPRESSION') %}
                                {{ include('logescom/commercial/client/_delete_form.html.twig') }}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
