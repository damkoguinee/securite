{% extends 'base_site.html.twig' %}

{% block title %}Fiche Client – {{ client.reference|upper }}{% endblock %}

{% block presentation %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-10">

            {% include "_common/_messages_flash.html.twig" %}

            <!-- =============================== -->
            <!-- 🧾 FICHE CLIENT -->
            <!-- =============================== -->
            <div class="card shadow-lg border-0 rounded-3 mb-4">

                <!-- HEADER -->
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center p-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="fa fa-user me-2"></i>
                        Fiche client – {{ client.reference|upper }}
                    </h5>

                    {% if client.photo %}
                        <img src="{{ asset(chemin_images_clients ~ client.photo) }}"
                             class="rounded-circle shadow border border-light"
                             style="width:65px; height:65px; object-fit:cover;">
                    {% endif %}
                </div>

                <div class="card-body bg-light">

                    <!-- =============================== -->
                    <!-- 👤 Informations personnelles -->
                    <!-- =============================== -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-secondary text-white fw-bold">
                            <i class="fa fa-id-card me-2"></i> Informations personnelles
                        </div>

                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <table class="table table-sm table-borderless">

                                        <tr>
                                            <th class="w-25 text-muted">Statut</th>
                                            <td>
                                                <span class="badge bg-{{ client.statut == 'actif' ? 'success' : 'secondary' }}">
                                                    {{ client.statut|capitalize }}
                                                </span>
                                            </td>
                                        </tr>

                                        <tr>
                                            <th class="text-muted w-50">Référence</th>
                                            <td class="fw-semibold">{{ client.reference|upper }}</td>
                                        </tr>
                                        
                                        <tr>
                                            <th class="text-muted">Société</th>
                                            <td>{{ client.societe }}</td>
                                        </tr>
                                        <tr>
                                            <th class="text-muted">Nom complet</th>
                                            <td>{{ client.nomComplet }}</td>
                                        </tr>
                                        <tr>
                                            <th class="text-muted">Téléphone</th>
                                            <td><i class="fa fa-phone me-1 text-muted"></i>{{ client.telephone }}</td>
                                        </tr>
                                    </table>
                                </div>

                                <div class="col-md-6">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <th class="text-muted">Email</th>
                                            <td><i class="fa fa-envelope me-1 text-muted"></i>{{ client.email ?: 'Non renseigné' }}</td>
                                        </tr>
                                        <tr>
                                            <th class="text-muted">Sexe</th>
                                            <td>{{ client.sexe|capitalize }}</td>
                                        </tr>
                                        <tr>
                                            <th class="text-muted">Date de naissance</th>
                                            <td>{{ client.dateNaissance ? client.dateNaissance|date('d/m/Y') : 'N/A' }}</td>
                                        </tr>
                                        <tr>
                                            <th class="text-muted">Mode de Facturation</th>
                                            <td>{{ client.Modefacturation|capitalize }}</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- =============================== -->
                    <!-- 🏠 Adresse -->
                    <!-- =============================== -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-dark text-white fw-bold">
                            <i class="fa fa-map-marker-alt me-2"></i> Adresse
                        </div>

                        <div class="card-body">
                            <ul class="list-unstyled lh-lg">
                                <li><strong>Préfecture :</strong> {{ client.adresse.divisionLocale.parent.nom|default('N/A') }}</li>
                                <li><strong>Sous-préfecture :</strong> {{ client.adresse.divisionLocale.nom|default('N/A') }}</li>
                                <li><strong>Quartier :</strong> {{ client.adresse.nom|default('N/A') }}</li>
                                <li><strong>Complément :</strong> {{ client.complementAdresse|default('') }}</li>
                            </ul>
                        </div>
                    </div>

                    <!-- =============================== -->
                    <!-- 🏢 Sites du client -->
                    <!-- =============================== -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-info text-white fw-bold d-flex justify-content-between align-items-center">
                            <span><i class="fa fa-building me-2"></i> Sites du client</span>

                            <a href="{{ path('app_logescom_commercial_bien_new', { site: site.id, client: client.id }) }}"
                               class="btn btn-light btn-sm">
                                <i class="fa fa-plus-circle me-1"></i> Ajouter un site
                            </a>
                        </div>

                        <div class="card-body">

                            {% if client.biens|length > 0 %}
                                <div class="table-responsive">
                                    <table class="table table-hover table-sm align-middle">
                                        <thead class="table-light text-center">
                                            <tr>
                                                <th>#</th>
                                                <th>Nom</th>
                                                <th>Adresse</th>
                                                <th>Type</th>
                                                <th>Statut</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for bien in client.biens %}
                                                <tr>
                                                    <td class="text-center">{{ loop.index }}</td>
                                                    <td class="fw-semibold">{{ bien.nom|capitalize }}</td>
                                                    <td>
                                                        {{ bien.adresse.nom|capitalize }}
                                                        {% if bien.adresse.divisionLocale %}
                                                            <small class="text-muted">({{ bien.adresse.divisionLocale.nom }})</small>
                                                        {% endif %}
                                                    </td>
                                                    <td class="text-center">{{ bien.typeBien.nom|capitalize }}</td>
                                                    <td class="text-center">
                                                        <span class="badge bg-{{ bien.statut == 'actif' ? 'success' : 'secondary' }}">
                                                            {{ bien.statut|capitalize }}
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <a href="{{ path('app_logescom_commercial_bien_show', {'id': bien.id, 'site': site.id}) }}"
                                                           class="btn btn-outline-success btn-sm">
                                                            <i class="fa fa-eye"></i>
                                                        </a>
                                                        <a href="{{ path('app_logescom_commercial_bien_edit', {'id': bien.id, 'site': site.id}) }}"
                                                           class="btn btn-outline-warning btn-sm">
                                                            <i class="fa fa-edit"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="alert alert-secondary text-center">
                                    <i class="fa fa-info-circle me-1"></i>
                                    Aucun site enregistré.
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- =============================== -->
                    <!-- 💳 Groupes de facturation -->
                    <!-- =============================== -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-success text-white fw-bold d-flex justify-content-between align-items-center">
                            <span>
                                <i class="fa fa-layer-group me-2"></i>
                                Groupes de facturation
                            </span>

                            <form method="post"
                                action="{{ path(
                                    'app_logescom_commercial_client_show',
                                    { id: client.id, site: site.id }
                                ) }}"
                                class="d-flex gap-2 ">

                                <input type="text"
                                    name="nom"
                                    class="form-control form-control-sm"
                                    placeholder="Nom du groupe de facturation"
                                    required
                                    maxlength="100">

                                <button class="btn btn-warning btn-sm px-3" name='groupeFacturation' value="groupeFcaturation">
                                    <i class="fa fa-check me-1"></i>
                                    Valider
                                </button>
                            </form>

                        </div>

                        <div class="card-body">

                            {% if client.groupeFacturations|length > 0 %}
                                {% for groupe in client.groupeFacturations %}
                                    <div class="border rounded p-3 mb-3 bg-light">

                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <strong>
                                                <i class="fa fa-folder-open me-1"></i>
                                                {{ groupe.nom }}
                                            </strong>

                                            <a href="{{ path(
                                                'app_logescom_commercial_client_show',
                                                { id: client.id, site: site.id, delete: groupe.id }
                                            ) }}"
                                            class="btn btn-outline-danger btn-sm"
                                            title="Supprimer le groupe">
                                                <i class="fa fa-trash"></i>
                                            </a>
                                        </div>

                                        {# ➕ AJOUT D’UN BIEN AU GROUPE #}
                                        <form method="post" class="d-flex gap-2 mb-2">
                                            <input type="hidden" name="groupe_id" value="{{ groupe.id }}">

                                            <select name="bien_id" class="form-select form-select-sm" required>
                                                <option value="">— Ajouter un site —</option>
                                                {% for bien in client.biens %}
                                                    {% if bien.groupeFacturation is null %}
                                                        <option value="{{ bien.id }}">
                                                            {{ bien.nom }}
                                                        </option>
                                                    {% endif %}
                                                {% endfor %}
                                            </select>

                                            <button class="btn btn-outline-primary btn-sm">
                                                <i class="fa fa-plus"></i>
                                            </button>
                                        </form>

                                        {# 📋 LISTE DES BIENS DU GROUPE #}
                                        {% if groupe.biens|length > 0 %}
                                            <ul class="list-group list-group-flush">
                                                {% for bien in groupe.biens %}
                                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                                        <span>
                                                            <i class="fa fa-building me-1 text-muted"></i>
                                                            {{ bien.nom }}
                                                        </span>

                                                        <a href="{{ path(
                                                            'app_logescom_commercial_client_show',
                                                            { id: client.id, site: site.id, detach: bien.id }
                                                        ) }}"
                                                        class="btn btn-outline-warning btn-sm"
                                                        title="Retirer du groupe">
                                                            <i class="fa fa-unlink"></i>
                                                        </a>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% else %}
                                            <div class="text-muted fst-italic">
                                                Aucun site rattaché à ce groupe
                                            </div>
                                        {% endif %}
                                    </div>

                                {% endfor %}
                            {% else %}
                                <div class="alert alert-secondary text-center mb-0">
                                    <i class="fa fa-info-circle me-1"></i>
                                    Aucun groupe de facturation créé pour ce client.
                                </div>
                            {% endif %}
                        </div>
                    </div>


                    <!-- =============================== -->
                    <!-- 📎 Documents -->
                    <!-- =============================== -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-warning fw-bold">
                            <i class="fa fa-file-alt me-1"></i> Documents officiels
                        </div>

                        <div class="card-body">

                            {% if client.documentUsers|length > 0 %}
                                <ul class="list-group">
                                    {% for doc in client.documentUsers %}
                                        <li class="list-group-item d-flex justify-content-between align-items-center">

                                            <div>
                                                <strong>{{ doc.titre|capitalize }}</strong><br>
                                                <small class="text-muted">{{ doc.fichier }}</small>
                                            </div>

                                            {% if doc.fichier %}
                                                <a href="{{ asset(chemin_images_clients ~ doc.fichier) }}"
                                                   target="_blank"
                                                   class="btn btn-outline-primary btn-sm">
                                                    <i class="fa fa-eye"></i> Voir
                                                </a>
                                            {% else %}
                                                <span class="text-muted fst-italic">Aucun fichier</span>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <p class="text-muted">Aucun document joint.</p>
                            {% endif %}
                        </div>
                    </div>

                    <!-- =============================== -->
                    <!-- 🔙 ACTIONS -->
                    <!-- =============================== -->
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('app_logescom_commercial_client_index', { site: site.id }) }}"
                           class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1"></i> Retour
                        </a>

                        <div class="d-flex gap-2">
                            {% if is_granted('ROLE_MODIFICATION') %}
                                <a href="{{ path('app_logescom_commercial_client_edit', { id: client.id, site: site.id }) }}"
                                   class="btn btn-warning">
                                    <i class="fa fa-edit me-1"></i> Modifier
                                </a>
                            {% endif %}

                            {% if is_granted('ROLE_SUPPRESSION') %}
                                {{ include('logescom/commercial/client/_delete_form.html.twig') }}
                            {% endif %}
                        </div>
                    </div>

                </div> <!-- card-body -->
            </div> <!-- main card -->

        </div>
    </div>
</div>
{% endblock %}
