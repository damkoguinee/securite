{% extends 'base_site.html.twig' %}

{% set queryParams = app.request.query.all %}
{% set queryString = queryParams|filter((v, k) => k != "page" and k != "ajustement" and k != "id_stock") | url_encode %}

{% block title %}Ajouter un client{% endblock %}

{% block presentation %}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-10">

            <!-- 🏷️ En-tête -->
            <div class="text-center mb-1">
                <p class="text-muted fs-6">
                    Renseignez les informations du client avec soin avant d’enregistrer.
                </p>
            </div>

            <!-- 🧾 Carte principale -->
            <div class="card border-0 shadow-lg rounded-3">
                <div class="card-body p-2 bg-light">

                    <!-- 🧍‍♂️ Formulaire du client -->
                    {{ include('logescom/commercial/client/_form.html.twig', {'button_label': 'Ajouter'}) }}

                    <hr class="my-2">

                    <!-- 🔙 Bouton de retour -->
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_logescom_commercial_bien_new', {'site': site.id}) }}" 
                           class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

{% endblock %}
