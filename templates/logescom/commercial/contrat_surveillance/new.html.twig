{% extends 'base_site.html.twig' %}

{% block title %}Nouveau contrat de surveillance{% endblock %}

{% block presentation %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-md-10">
            {{ include("_common/_messages_flash.html.twig") }}

            <!-- 🏷️ En-tête -->
            <div class="text-center mb-3">
                <h4 class="fw-bold text-primary">
                    <i class="fa fa-file-contract me-2"></i> Nouveau contrat de surveillance
                </h4>
                <p class="text-muted mb-0">
                    Veuillez renseigner les informations relatives au contrat avant d’enregistrer.
                </p>
            </div>

            <!-- 🧾 Carte principale -->
            <div class="card border-0 shadow-lg rounded-3">
                <div class="card-body p-4 bg-light">

                    <!-- 🧍‍♂️ Formulaire -->
                    {{ include('logescom/commercial/contrat_surveillance/_form.html.twig', {'button_label': 'Enregistrer'}) }}

                    <hr class="my-4">

                    <!-- 🔙 Bouton retour -->
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_logescom_commercial_contrat_surveillance_index', {'site': site.id}) }}" 
                           class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1"></i> Retour à la liste
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
