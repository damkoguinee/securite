{% extends 'base_site.html.twig' %}

{% block title %}Modification du contrat complementaire{% endblock %}

{% block presentation %}
<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-md-10">

            <!-- 🏷️ En-tête -->
            <div class="text-center mb-3">
                <h4 class="fw-bold text-primary">
                    <i class="fa fa-edit me-2"></i> Modifier un contrat complementaire
                </h4>
                <p class="text-muted mb-0">
                    Mettez à jour les informations du contrat avant d’enregistrer vos modifications.
                </p>
            </div>

            <!-- 🧾 Carte principale -->
            <div class="card border-0 shadow-lg rounded-3">
                <div class="card-body p-4 bg-light">

                    <!-- 🧍‍♂️ Formulaire -->
                    {{ include('logescom/commercial/contrat_surveillance/contrat_complementaire/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

                    <hr class="my-4">

                    <!-- 🔘 Boutons d’action -->
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_logescom_commercial_contrat_surveillance_show', {
                            id : contrat_complementaire.contrat.id,
                            site: site.id
                        }) }}" 
                           class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1"></i> Retour au contrat
                        </a>

                        <div class="d-flex gap-2">
                            {% if is_granted('ROLE_SUPPRESSION') %}
                                {{ include('logescom/commercial/contrat_surveillance/contrat_complementaire/_delete_form.html.twig') }}
                            {% endif %}
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
