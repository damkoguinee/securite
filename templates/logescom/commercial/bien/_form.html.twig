{{ form_errors(form) }}
{{ form_start(form) }}

<div class="row">
    <div class="col-md-3 mb-3">
        {{ form_row(form.zoneRattachement) }}
    </div>
    <div class="col-md-3 mb-3">
        {{ form_row(form.nom) }}
    </div>
    <div class="col-md-6 mb-3">
        {{ form_row(form.description) }}
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        {{ form_row(form.typeBien) }}
    </div>
    <div class="col-md-4 mb-3">
        {{ form_row(form.statut) }}
    </div>
    <div class="col-md-4 mb-3">
        {{ form_row(form.site) }}
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="d-flex justify-content-between align-items-center">
            <label for="bien_client" class="form-label fw-semibold">
                Propriétaire *
            </label>
            <a href="{{ path('app_logescom_commercial_client_new', {site : site.id}) }}" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-plus-circle"></i> Nouveau client
            </a>
        </div>
        {{ form_widget(form.client) }}
        {{ form_errors(form.client) }}
    </div>

    <div class="col-md-6 mb-3">
        {{ form_row(form.adresse) }}
    </div>
</div>


<hr class="my-4">

<div class="row">
    <div class="col-md-6 mb-3">
        {{ form_row(form.latitude) }}
    </div>
    <div class="col-md-6 mb-3">
        {{ form_row(form.longitude) }}
    </div>
</div>

<div class="text-end mt-4">
    <button class="btn btn-primary">
        {{ button_label|default('Enregistrer') }}
    </button>
</div>

{{ form_end(form) }}
