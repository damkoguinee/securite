            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
            <link rel="stylesheet" href="{{asset('css/style.css')}}">

        {% endblock %}

        {% block javascripts %}
            <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.4/jquery.min.js" integrity="sha512-pumBsjNRGGqkPzKHndZMaAG+bir374sORyzM3uulLV14lN5LyykqNk8eEeUlUkB3U0M4FApyaHraT65ihJhDpQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

		    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>

            <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/js/all.min.js" integrity="sha512-b+nQTCdtTBIRIbraqNEwsjB6UvL3UEMkXnhzd8awtCYh0Kcsjl9uEgwVFVbhoj3uu1DO1ZMacNvLoyJJiNfcvg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
            <script src="{{ asset('js/main.js') }}"></script>



        {% endblock %} #}
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('css/fontawesome/css/all.min.css') }}">
            <link rel="stylesheet" href="{{ asset('css/bootstrap/css/bootstrap.min.css') }}">
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
            {{ encore_entry_link_tags('all-styles') }}
        {% endblock %}
        <link rel="manifest" href="{{ asset('build/pwa-manifest.json') }}">
    </head>
    <body>
        {% block body %}
            {% block header %}
                <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background-color:#152736; height:70px;">
                    <div class="container-fluid">

                        <!-- LOGO -->
                        <a class="navbar-brand d-flex align-items-center" href="{{ path('app_logescom_home') }}">
                            {% if entreprise.logo is not empty %}
                                <img src="{{ asset(chemin_images_logos ~ entreprise.logo) }}"
                                    height="50" class="me-2" alt="Logo">
                            {% else %}
                                <img src="{{ asset('images/config/default.jpg') }}"
                                    height="50" class="me-2" alt="Logo">
                            {% endif %}
                        </a>

                        <!-- Burger mobile -->
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navEntreprise">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <!-- NAV CONTENU -->
                        <div class="collapse navbar-collapse" id="navEntreprise">

                            <!-- LEFT MENU -->
                            <ul class="navbar-nav me-auto">

                                <li class="nav-item">
                                    <a class="nav-link {{ app.current_route starts with 'app_logescom_home' ? 'active text-warning' }}"
                                    href="{{ path('app_logescom_home') }}">
                                        <i class="fa fa-home me-1"></i> Accueil
                                    </a>
                                </li>

                            </ul>

                            <!-- RIGHT (User) -->
                            <ul class="navbar-nav ms-auto">

                                {% if not app.user %}

                                    <li class="nav-item">
                                        <a class="nav-link text-white" href="{{ path('app_login') }}">
                                            <i class="fa fa-user-circle me-1"></i>
                                            Connexion
                                        </a>
                                    </li>

                                {% else %}

                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle text-white"
                                        href="#" id="userDropdown" data-bs-toggle="dropdown">
                                            <i class="fa fa-user-circle me-1"></i>
                                            {{ app.user.username|capitalize }}
                                        </a>

                                        <ul class="dropdown-menu dropdown-menu-end shadow">

                                            <li>
                                                <a class="dropdown-item" href="#">
                                                    <i class="fa fa-id-badge text-primary me-1"></i> Profil
                                                </a>
                                            </li>

                                            <li><hr class="dropdown-divider"></li>

                                            <li>
                                                <a class="dropdown-item text-danger fw-bold"
                                                href="{{ path('app_logout') }}">
                                                    <i class="fa fa-power-off me-1"></i>
                                                    Déconnexion
                                                </a>
                                            </li>

                                        </ul>
                                    </li>

                                {% endif %}

                            </ul>

                        </div>

                    </div>
                </nav>

            {% endblock %}
            {% block carousel %}
                <div id="carouselExampleAutoplaying" class="carousel slide py-2" data-bs-ride="carousel"></div>
            {% endblock %}
            {% block main %}
                <main class="my-2" id="main-content">
                    {% block presentation %}

                    {% endblock %}
                </main>
            {% endblock %}
            {% block footer %}
            {% endblock %}
        {% endblock %}

        {% block javascripts %}
            <script src="{{ asset('css/fontawesome/js/all.min.js') }}"></script>
            {{ encore_entry_script_tags('all-scripts') }}
            <script src="{{ asset('css/bootstrap/js/bootstrap.bundle.min.js') }}"></script>

        {% endblock %}
    </body>
</html>
